/// Banco de horas (1:N, ledger). Saldo atual = SUM(hours). Positivo = credito
/// (hora extra), negativo = debito (compensacao).
model ConsultantHourBankEntry {
  id           String            @id @default(cuid())
  consultantId String
  consultant   Consultant        @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  occurredAt   DateTime
  kind         HourBankEntryKind
  hours        Decimal           @db.Decimal(6, 2)
  note         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([consultantId, occurredAt])
}

/// Natureza de uma remuneracao pontual (Onda D). BONUS = premio/gratificacao;
/// ADJUSTMENT = acerto/correcao de valor; OTHER = demais casos (default).
enum AdHocPaymentKind {
  BONUS
  ADJUSTMENT
  OTHER
}

/// Estado de uma remuneracao pontual (Onda D). PLANNED (prevista, entra na
/// projecao de custo/margem) -> PAID (paga) ou CANCELLED (cancelada). Transicoes
/// e reflexo na margem sao decididos na aplicacao.
enum AdHocPaymentStatus {
  PLANNED
  PAID
  CANCELLED
}

/// Remuneracao pontual do consultor (Onda D / decisao D2). Sempre VINCULADA a um
/// projeto (obrigatorio): a pontual entra no custo/margem daquele projeto, por
/// isso projectId nao e opcional e usa onDelete Restrict (nao apagar projeto com
/// pontual atrelada; historico financeiro deve ser preservado). allocationId e
/// opcional (SetNull) para permitir vincular a uma alocacao especifica sem
/// perder o registro se a alocacao for removida. consultantId usa Cascade
/// (segue o ciclo do consultor, alinhado a timeOffs/hourBankEntries). Dado
/// financeiro: leitura/escrita restrita a perfis autorizados e alteracoes
/// sensiveis (valor, status) devem gerar AuditEvent na aplicacao.
model ConsultantAdHocPayment {
  id              String             @id @default(cuid())
  consultantId    String
  consultant      Consultant         @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  projectId       String
  project         Project            @relation(fields: [projectId], references: [id], onDelete: Restrict)
  allocationId    String?
  allocation      Allocation?        @relation(fields: [allocationId], references: [id], onDelete: SetNull)
  amount          Decimal            @db.Decimal(12, 2)
  /// Data prevista de pagamento (date-only, mesma convencao de Expense/dueAt).
  payAt           DateTime           @db.Date
  reason          String
  kind            AdHocPaymentKind   @default(OTHER)
  status          AdHocPaymentStatus @default(PLANNED)
  /// Referencia solta ao User que criou (padrao de managerUserId/closedByUserId):
  /// sem FK, para nao acoplar auditoria ao ciclo de vida de User.
  createdByUserId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([consultantId])
  @@index([projectId])
  @@index([payAt])
}

/// @deprecated Melhoria #2: Sobreaviso passou a ser um TimeEntry (activityType
/// ON_CALL) com status proprio de TimeEntryStatus. Enum mantido (NAO dropar)
/// enquanto a migracao de dados e a remocao das telas legadas nao concluem.
enum OnCallStatus {
  PENDING
  APPROVED
  REJECTED
}

/// @deprecated Melhoria #2: Sobreaviso virou Atividade na tela de Horas. Os
/// lancamentos passam a viver em TimeEntry (activityType ON_CALL, multiplier,
/// attachment via TimeEntryAttachment). Este modelo NAO deve ser dropado ainda:
/// e a origem do script de migracao de dados e mantem o historico legado.
///
/// Sobreaviso (on-call): horas de prontidao de um consultor, com fator de
/// remuneracao (multiplier) e anexo com o "ok" do responsavel. Aprovacao por
/// gestor (PENDING -> APPROVED/REJECTED) gravada em status + AuditEvent.
/// `date` em UTC midnight (date-only, mesma convencao de TimeEntry/Expense).
model OnCallEntry {
  id               String            @id @default(cuid())
  consultantId     String
  consultant       Consultant        @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  projectId        String?
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  date             DateTime
  hours            Decimal           @db.Decimal(6, 2)
  /// Fator de remuneracao do sobreaviso (ex.: 0.33). Default 1.00.
  multiplier       Decimal           @default(1.00) @db.Decimal(5, 2)
  status           OnCallStatus      @default(PENDING)
  note             String?
  approvedByUserId String?
  approvedAt       DateTime?
  createdByUserId  String?
  attachment       OnCallAttachment?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([consultantId, date])
  @@index([status])
  @@index([projectId])
}

/// @deprecated Melhoria #2: sucedido por TimeEntryAttachment (anexo generico de
/// TimeEntry). Mantido (NAO dropar) ate a migracao de dados copiar os anexos e
/// as telas legadas serem removidas.
///
/// Anexo do "ok do responsavel" para um sobreaviso (1:1). Mesmo padrao do
/// ExpenseAttachment: bucket privado + chave de storage; URL sempre assinada.
model OnCallAttachment {
  id               String      @id @default(cuid())
  onCallEntryId    String      @unique
  onCallEntry      OnCallEntry @relation(fields: [onCallEntryId], references: [id], onDelete: Cascade)
  fileName         String
  contentType      String
  size             Int
  storageBucket    String
  storageKey       String
  uploadedByUserId String?
  createdAt        DateTime    @default(now())
}

/// Dados especificos PJ: contratacao + faturamento (1:1). A identidade da
