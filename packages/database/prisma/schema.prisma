enum ConsultantDocumentType {
  PROOF_OF_ADDRESS
  RG
  CPF
  CTPS
  CERTIFICATE
  EMPLOYMENT_CONTRACT
  ASO_ADMISSIONAL
  SERVICE_CONTRACT
  CNPJ_CARD
  ARTICLES_OF_ASSOCIATION
  NEGATIVE_CERTIFICATE
  BANK_PROOF
  OTHER
}

enum LanguageLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
  FLUENT
  NATIVE
}

enum EducationDegree {
  HIGH_SCHOOL
  TECHNICAL
  UNDERGRADUATE
  POSTGRADUATE
  MASTERS
  DOCTORATE
  OTHER
}

