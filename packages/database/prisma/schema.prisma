  INTERMEDIATE
  ADVANCED
  FLUENT
  NATIVE
}

enum EducationDegree {
  HIGH_SCHOOL
  TECHNICAL
  UNDERGRADUATE
  POSTGRADUATE
  MASTERS
  DOCTORATE
  OTHER
}

/// Modalidade do contrato CLT (obrigacoes trabalhistas), distinta do
