  CANCELLED
}

enum FiscalDocumentKind {
  NFSE
  PRODUCT_INVOICE
}

enum IntegrationProviderKind {
  CNPJ
  CEP
  ENTRA_ID
  SAO_PAULO_NFSE
  EMAIL
  STORAGE
  BANK
  ERP
  /// Canal de notificacao via webhook de saida (Microsoft Teams Incoming Webhook).
  TEAMS
}

enum IntegrationEventStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

/// Visibilidade de um post do feed social interno (Melhoria #5). No v1 so
/// PUBLIC_INTERNAL esta ativa na UI (toda a empresa ve). AREA fica modelado para
/// segmentacao futura por area (usa FeedPost.areaScope), mas desligado no produto.
enum FeedVisibility {
  PUBLIC_INTERNAL
  AREA
}

/// Estado de um post ou comentario do feed (soft delete por status, padrao das
/// entidades operacionais). VISIBLE = ativo; DELETED_BY_AUTHOR = removido pelo
/// proprio autor; REMOVED_BY_MODERATION = retirado por ADMIN/PEOPLE (guarda
/// removedByUserId/removedAt/removalReason para auditoria).
enum FeedContentStatus {
  VISIBLE
  DELETED_BY_AUTHOR
  REMOVED_BY_MODERATION
}

/// Tipo de um registro de acompanhamento do consultor (Melhoria #4). ONE_ON_ONE e
/// a conversa 1-on-1 (por padrao PRIVATE: o consultor nao ve); CHECKPOINT e um
/// ponto de acompanhamento mais amplo (semanal/quinzenal por projeto). So o GESTOR
/// registra; a distincao orienta visibilidade padrao e UI, nao regra de banco.
enum CheckpointType {
  ONE_ON_ONE
  CHECKPOINT
}

/// Ciclo de vida de um Checkpoint. DRAFT = rascunho; RECORDED = registrado
/// (texto/audio salvos); EXTRACTED = a IA ja extraiu insights (skills,
/// oportunidades, cases); ARCHIVED = arquivado (soft delete operacional).
/// Transicoes aplicadas no servidor; nao retrocede de ARCHIVED.
enum CheckpointStatus {
  DRAFT
  RECORDED
  EXTRACTED
  ARCHIVED
}

/// Visibilidade de um Checkpoint (LGPD/confianca). PRIVATE (padrao do 1-on-1) so e
/// visto por autor/gestor + PEOPLE; o consultor avaliado NAO ve. SHARED libera o
/// registro ao consultor. Regra aplicada no servidor.
enum CheckpointVisibility {
  PRIVATE
  SHARED
}

/// Estado da extracao de insights por IA a partir do Checkpoint. NONE = ainda nao
/// solicitada; PENDING = na fila; DONE = concluida (insights gerados); FAILED =
/// falhou. Apenas coluna de apoio; a logica de extracao vive fora do banco.
enum CheckpointExtractionStatus {
  NONE
  PENDING
  DONE
  FAILED
}

/// Estado de um insight extraido por IA pendente de curadoria humana. Reusa o
/// padrao de SkillSuggestionStatus: PENDING (aguardando decisao do gestor),
/// ACCEPTED (promovido a registro real), DISMISSED (descartado).
enum CheckpointInsightStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

/// Natureza de uma Oportunidade (chance futura a agir, INTERNA + handoff manual,
/// sem CRM). EXPANSION = ampliar escopo na conta; UPSELL = vender mais ao mesmo
/// cliente; RISK = risco de conta/churn a tratar; REFERRAL = indicacao para outra
/// area/cliente; RENEWAL = renovacao de contrato a encaminhar.
enum OpportunityKind {
  EXPANSION
  UPSELL
  RISK
  REFERRAL
  RENEWAL
}

/// Prioridade de uma Oportunidade para triagem do gestor/comercial.
enum OpportunityPriority {
  LOW
  MEDIUM
  HIGH
}

/// Estagio de maturidade de um Case (entrega concluida digna de referencia, INTERNO).
/// DRAFT_INSIGHT = insight bruto extraido pela IA; APPROVED = revisado e aprovado
/// internamente; PUBLISHABLE = liberado para uso comercial/referencia (sujeito a
/// consentimento do cliente, registrado em clientConsentState).
enum CaseStage {
  DRAFT_INSIGHT
  APPROVED
  PUBLISHABLE
}

model User {
  id                          String                      @id @default(cuid())
  name                        String
  email                       String                      @unique
  status                      UserStatus                  @default(ACTIVE)
  // Local credentials provider (Round 5). Nullable: Entra users and not-yet
  // accepted invitations have no password. Format is the self-describing
  // scrypt string `scrypt$N$r$p$<saltB64url>$<hashB64url>` (see auth-foundation
  // 11.3). Never store or log the plaintext password.
  passwordHash                String?
  emailVerifiedAt             DateTime?
  lastLoginAt                 DateTime?
  mustChangePassword          Boolean                     @default(false)
  roles                       UserRole[]
  consultant                  Consultant?
  auditEvents                 AuditEvent[]                @relation("AuditActor")
  approvals                   Approval[]                  @relation("ApprovalApprover")
  uploadedExpenseAttachments  ExpenseAttachment[]         @relation("ExpenseAttachmentUploader")
  uploadedConsultantDocuments ConsultantDocument[]        @relation("ConsultantDocumentUploader")
  closedRevenueClosings       RevenueClosing[]            @relation("RevenueClosingCloser")
  validatedFiscalDocuments    FiscalDocument[]            @relation("FiscalDocumentValidator")
  paymentForecastsCreated     ConsultantPaymentForecast[] @relation("PaymentForecastCreator")
  consultantPaymentsApproved  ConsultantPayment[]         @relation("ConsultantPaymentApprover")
  skillHistoryChanges         ConsultantSkillHistory[]    @relation("SkillHistoryChangedBy")
  feedbacksAuthored           Feedback[]                  @relation("FeedbackAuthor")
  evaluationCyclesCreated     EvaluationCycle[]           @relation("EvaluationCycleCreator")
  evaluationResponsesAsRater  EvaluationResponse[]        @relation("EvaluationResponseRater")
  developmentPlansOwned       DevelopmentPlan[]           @relation("DevelopmentPlanOwner")
  curriculumSnapshotsCreated  ConsultantCurriculumSnapshot[] @relation("CurriculumSnapshotGeneratedBy")
  surveysCreated              Survey[]                    @relation("SurveyCreator")
  objectivesOwned             Objective[]                 @relation("ObjectiveOwner")
  // Feed social interno (Melhoria #5, fatia 1). Autoria por User com onDelete
  // SetNull: remover o usuario nao apaga o post/comentario, apenas desvincula a
  // autoria (preserva o historico). Reacoes sao do proprio usuario e somem com ele.
  feedPostsAuthored           FeedPost[]                  @relation("FeedPostAuthor")
  feedCommentsAuthored        FeedComment[]               @relation("FeedCommentAuthor")
  feedReactions               FeedReaction[]              @relation("FeedReactionUser")
  feedMentions                FeedMention[]               @relation("FeedMentionUser")
  // Checkpoint/1-on-1 + entidades de inteligencia (Melhoria #4, fatia 1). Autoria
  // por User com onDelete SetNull em todas: remover o usuario nao apaga o
  // historico (checkpoint, oportunidade, case) — apenas desvincula a autoria.
  checkpointsManaged          Checkpoint[]                @relation("CheckpointManager")
  opportunitiesDecided        Opportunity[]               @relation("OpportunityDecider")
  opportunitiesOwned          Opportunity[]               @relation("OpportunityOwner")
  casesDecided                Case[]                      @relation("CaseDecider")
  // Invitations this user created (actor side) and the invitation that created
  // this user on acceptance (at most one).
  invitationsSent             UserInvitation[]            @relation("InvitedBy")
  invitationCreated           UserInvitation?             @relation("CreatedUser")
  // Aceite dos Termos de Uso (EP-M08). Um registro por versao aceita; a versao
  // vigente exigida esta em apps/web/src/lib/terms (CURRENT_TERMS_VERSION).
  termsAcceptances            TermsAcceptance[]           @relation("TermsAcceptanceUser")
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
}

/// Aceite dos Termos de Uso e Politica de Uso Aceitavel (EP-M08). O gate no
/// layout autenticado bloqueia o acesso ate existir um aceite da versao vigente.
/// Idempotente por (userId, termsVersion): reaceitar a mesma versao nao duplica.
/// O texto canonico vive em docs/termos-de-uso-jumpflow.md e e derivado para a
/// UI em apps/web/src/lib/terms/terms.ts.
model TermsAcceptance {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("TermsAcceptanceUser", fields: [userId], references: [id], onDelete: Cascade)
  /// Versao dos Termos aceita (ex.: "1.0"). Casa com CURRENT_TERMS_VERSION.
  termsVersion String
  acceptedAt   DateTime @default(now())

  @@unique([userId, termsVersion])
  @@index([userId])
}

/// Grupo de acesso (perfil) do RBAC. Os 7 grupos do sistema têm `name` (enum
/// RoleName) e `isSystem = true`; grupos criados dinamicamente pela tela de
/// Matriz de Permissões têm `name = null` e identificam-se pelo `key` (slug).
/// A resolução de permissões (RolePermission) é sempre por `id`/roleId, nunca
/// pelo enum, então grupos dinâmicos funcionam sem refatorar a camada de auth.
model Role {
  id          String           @id @default(cuid())
  /// Nullable: só os grupos do sistema mapeiam para o enum RoleName. Grupos
  /// dinâmicos têm name = null e são identificados por `key`.
  name        RoleName?        @unique
  /// Slug estável e único. Para grupos do sistema = string do enum (ex. "ADMIN").
  key         String           @unique
  /// Rótulo legível (pt-BR) exibido na UI; para grupos do sistema vem de roleLabels.
  label       String?
  description String?
  active      Boolean          @default(true)
  /// Grupo nativo da plataforma (não pode ser excluído; ADMIN não pode ser inativado).
  isSystem    Boolean          @default(true)
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt
}

/// Funcionalidade do sistema no RBAC configurável (módulo ou submódulo).
/// Hierarquia via self-relation (parent/children). O `code` é o identificador
/// estável usado por can()/requirePermission() (ex. "HORAS", "HORAS_APROVACOES").
/// Cadastro dinâmico: novas funcionalidades podem ser criadas sem alterar código.
model Permission {
  id              String           @id @default(cuid())
  /// Código estável e único usado pelos guards (UPPER_SNAKE_CASE).
  code            String           @unique
  name            String
  /// Rótulo do módulo de topo (ex. "Horas"), usado para agrupar na matriz.
  module          String
  description     String?
  active          Boolean          @default(true)
  /// Hierarquia módulo → submódulo. SetNull mantém o filho se o pai sumir.
  parentId        String?
  parent          Permission?      @relation("PermissionTree", fields: [parentId], references: [id], onDelete: SetNull)
  children        Permission[]     @relation("PermissionTree")
  /// Ordem de exibição dentro do módulo.
  sortOrder       Int              @default(0)
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([module])
  @@index([parentId])
}

/// Célula da matriz de permissões: o que um grupo (Role) pode fazer em uma
/// funcionalidade (Permission). Quatro ações independentes. A ausência de linha
/// equivale a tudo negado. Evolução futura (FLS/RLS/escopo por projeto/cliente)
/// entra de forma aditiva via colunas scopeType/scopeId nullable ou tabela
/// PermissionScope — sem refatorar esta estrutura.
model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  canView      Boolean    @default(false)
  canCreate    Boolean    @default(false)
  canEdit      Boolean    @default(false)
  canDelete    Boolean    @default(false)
  updatedAt    DateTime   @default(now()) @updatedAt

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

/// Invitation-only onboarding (Round 5). There is no public sign-up: a user
/// enters the platform solely by accepting an invitation created by an ADMIN.
/// The invite token is a high-entropy secret delivered once; only its sha256
/// digest is stored in `tokenHash` (@unique), never the plaintext token.
/// `roles` carries the RoleName enum array to grant on acceptance, kept in the
/// row (no join table) since the role set is small and static for the MVP and
/// is written/read atomically with the invitation. Acceptance is single-use
/// + TTL-bound (`expiresAt`); status transitions and the
/// re-hash/lookup/validate flow are enforced in Server Actions.
model UserInvitation {
  id              String           @id @default(cuid())
  // Normalized to lowercase in the application layer before persisting.
  email           String
  name            String
  // sha256 digest of the plaintext token (hex/base64url). Plaintext is never
  // stored. @unique enforces single active digest per token.
  tokenHash       String           @unique
  status          InvitationStatus @default(PENDING)
  // Roles to grant when the invitation is accepted. Native Postgres enum array.
  roles           RoleName[]
  expiresAt       DateTime
  acceptedAt      DateTime?
  // Actor who created the invitation. Restrict so an admin with open invites
  // cannot be hard-deleted without first resolving them (audit integrity).
  invitedByUserId String
  invitedBy       User             @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  // Populated on acceptance with the created/activated user. SetNull keeps the
  // invitation history if that user is later removed.
  createdUserId   String?          @unique
  createdUser     User?            @relation("CreatedUser", fields: [createdUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([email])
  @@index([status])
}

model Consultant {
  id                  String                         @id @default(cuid())
  userId              String?                        @unique
  user                User?                          @relation(fields: [userId], references: [id])
  name                String
  email               String                         @unique
  jobTitle            String?
  seniority           Seniority
  area                String?
  status              ConsultantStatus               @default(ACTIVE)
  /// Tipo de contratacao que orienta quais secoes do cadastro aparecem.
  /// Distinto de ConsultantCompensation.contractType, que e a modalidade
  /// financeira por vigencia. Nullable para backfill; nao tornar obrigatorio
  /// sem antes preencher os registros existentes.
  contractType        ConsultantContractType?
  hourlyCost          Decimal?                       @db.Decimal(12, 2)
  /// Curriculo (EP-M06): bio curada por People. `headline` e uma linha curta
  /// (ex.: "Engenheira de dados focada em analytics"); `summary` e um resumo
  /// livre. Sao a UNICA parte nao-derivada do curriculo; o restante vem das
  /// tabelas-fonte. Nunca contem dados financeiros.
  curriculumHeadline  String?
  curriculumSummary   String?
  allocations         Allocation[]
  periods             TimesheetPeriod[]
  timeEntries         TimeEntry[]
  skills              ConsultantSkill[]
  skillSuggestions    SkillSuggestion[]
  certificates        Certificate[]
  autoApprovalRules   ConsultantAutoApprovalRule[]
  expenses            Expense[]
  personalInfo        ConsultantPersonalInfo?
  companyInfo         ConsultantCompanyInfo?
  address             ConsultantAddress?
  bankAccounts        ConsultantBankAccount[]
  compensations       ConsultantCompensation[]
  benefits            ConsultantBenefit[]
  documents           ConsultantDocument[]
  languages           ConsultantLanguage[]
  educations          ConsultantEducation[]
  cltInfo             ConsultantCltInfo?
  vacations           ConsultantVacation[]
  hourBankEntries     ConsultantHourBankEntry[]
  adHocPayments       ConsultantAdHocPayment[]
  onCallEntries       OnCallEntry[]
  pjInfo              ConsultantPjInfo?
  legalRepresentative ConsultantLegalRepresentative?
  paymentForecasts    ConsultantPaymentForecast[]
  payments            ConsultantPayment[]
  saleRates           ProjectSaleRate[]
  costRates           ConsultantAllocationCostRate[]
  feedbacks           Feedback[]                     @relation("FeedbackSubject")
  evaluations         Evaluation[]
  developmentPlans    DevelopmentPlan[]
  timeOffs            ConsultantTimeOff[]
  surveyInvitations   SurveyInvitation[]
  objectives          Objective[]
  enrollments         Enrollment[]
  curriculumSnapshots ConsultantCurriculumSnapshot[]
  // Checkpoint/1-on-1 + inteligencia (Melhoria #4). checkpoints sao Cascade no
  // consultor (o registro nao faz sentido sem o avaliado); oportunidade/case usam
  // SetNull no consultantId para preservar o insight comercial mesmo se o consultor
  // for removido.
  checkpoints         Checkpoint[]
  opportunities       Opportunity[]
  cases               Case[]
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
}

/// Snapshot versionado do curriculo do consultor (EP-M06 / US-M06.04). Congela
/// o agregado derivado (buildConsultantCurriculum) no momento da geracao em
/// `content` (JSON), para historico e versao imprimivel estavel. SEM assinatura
/// e SEM dados financeiros. `pdfStorageKey` fica reservado para uma futura
/// geracao server-side de PDF (hoje o PDF sai pelo navegador via impressao).
model ConsultantCurriculumSnapshot {
  id                String     @id @default(cuid())
  consultantId      String
  consultant        Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  /// Agregado congelado (identidade, formacao, idiomas, skills validadas,
  /// certificados, historico de projetos, destaques, bio curada).
  content           Json
  generatedByUserId String?
  generatedBy       User?      @relation("CurriculumSnapshotGeneratedBy", fields: [generatedByUserId], references: [id], onDelete: SetNull)
  /// Reservado para PDF gerado server-side no futuro. Nullable; nao usado agora.
  pdfStorageKey     String?
  createdAt         DateTime   @default(now())

  @@index([consultantId, createdAt])
}

