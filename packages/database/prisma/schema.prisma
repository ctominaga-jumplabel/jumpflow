  INVOICE_RECEIVED
  INVOICE_VALIDATED
  APPROVED_FOR_PAYMENT
  SENT_TO_BANK
  PROCESSED
  PAID
  CANCELLED
}

enum FiscalDocumentStatus {
  DRAFT
  REQUESTED
  ISSUED
  FAILED
  CANCELLED
}

enum FiscalDocumentKind {
  NFSE
  PRODUCT_INVOICE
}

enum IntegrationProviderKind {
  CNPJ
  CEP
  ENTRA_ID
  SAO_PAULO_NFSE
  EMAIL
  STORAGE
  BANK
  ERP
}

enum IntegrationEventStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

model User {
  id                          String                      @id @default(cuid())
  name                        String
  email                       String                      @unique
  status                      UserStatus                  @default(ACTIVE)
  // Local credentials provider (Round 5). Nullable: Entra users and not-yet
  // accepted invitations have no password. Format is the self-describing
  // scrypt string `scrypt$N$r$p$<saltB64url>$<hashB64url>` (see auth-foundation
  // 11.3). Never store or log the plaintext password.
  passwordHash                String?
  emailVerifiedAt             DateTime?
  lastLoginAt                 DateTime?
  mustChangePassword          Boolean                     @default(false)
  roles                       UserRole[]
  consultant                  Consultant?
  auditEvents                 AuditEvent[]                @relation("AuditActor")
  approvals                   Approval[]                  @relation("ApprovalApprover")
  uploadedExpenseAttachments  ExpenseAttachment[]         @relation("ExpenseAttachmentUploader")
  uploadedConsultantDocuments ConsultantDocument[]        @relation("ConsultantDocumentUploader")
  closedRevenueClosings       RevenueClosing[]            @relation("RevenueClosingCloser")
  validatedFiscalDocuments    FiscalDocument[]            @relation("FiscalDocumentValidator")
  paymentForecastsCreated     ConsultantPaymentForecast[] @relation("PaymentForecastCreator")
  consultantPaymentsApproved  ConsultantPayment[]         @relation("ConsultantPaymentApprover")
  skillHistoryChanges         ConsultantSkillHistory[]    @relation("SkillHistoryChangedBy")
  feedbacksAuthored           Feedback[]                  @relation("FeedbackAuthor")
  evaluationCyclesCreated     EvaluationCycle[]           @relation("EvaluationCycleCreator")
  evaluationResponsesAsRater  EvaluationResponse[]        @relation("EvaluationResponseRater")
  developmentPlansOwned       DevelopmentPlan[]           @relation("DevelopmentPlanOwner")
  // Invitations this user created (actor side) and the invitation that created
  // this user on acceptance (at most one).
  invitationsSent             UserInvitation[]            @relation("InvitedBy")
  invitationCreated           UserInvitation?             @relation("CreatedUser")
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
}

model Role {
  id        String     @id @default(cuid())
  name      RoleName   @unique
  users     UserRole[]
  createdAt DateTime   @default(now())
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

/// Invitation-only onboarding (Round 5). There is no public sign-up: a user
/// enters the platform solely by accepting an invitation created by an ADMIN.
/// The invite token is a high-entropy secret delivered once; only its sha256
/// digest is stored in `tokenHash` (@unique), never the plaintext token.
/// `roles` carries the RoleName enum array to grant on acceptance, kept in the
/// row (no join table) since the role set is small and static for the MVP and
/// is written/read atomically with the invitation. Acceptance is single-use
/// + TTL-bound (`expiresAt`); status transitions and the
/// re-hash/lookup/validate flow are enforced in Server Actions.
model UserInvitation {
  id              String           @id @default(cuid())
  // Normalized to lowercase in the application layer before persisting.
  email           String
  name            String
  // sha256 digest of the plaintext token (hex/base64url). Plaintext is never
  // stored. @unique enforces single active digest per token.
  tokenHash       String           @unique
  status          InvitationStatus @default(PENDING)
  // Roles to grant when the invitation is accepted. Native Postgres enum array.
  roles           RoleName[]
  expiresAt       DateTime
  acceptedAt      DateTime?
  // Actor who created the invitation. Restrict so an admin with open invites
  // cannot be hard-deleted without first resolving them (audit integrity).
  invitedByUserId String
  invitedBy       User             @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  // Populated on acceptance with the created/activated user. SetNull keeps the
  // invitation history if that user is later removed.
  createdUserId   String?          @unique
  createdUser     User?            @relation("CreatedUser", fields: [createdUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([email])
  @@index([status])
}

model Consultant {
  id                  String                         @id @default(cuid())
  userId              String?                        @unique
  user                User?                          @relation(fields: [userId], references: [id])
  name                String
  email               String                         @unique
  jobTitle            String?
  seniority           Seniority
  area                String?
  status              ConsultantStatus               @default(ACTIVE)
  /// Tipo de contratacao que orienta quais secoes do cadastro aparecem.
  /// Distinto de ConsultantCompensation.contractType, que e a modalidade
  /// financeira por vigencia. Nullable para backfill; nao tornar obrigatorio
  /// sem antes preencher os registros existentes.
  contractType        ConsultantContractType?
  hourlyCost          Decimal?                       @db.Decimal(12, 2)
  allocations         Allocation[]
  periods             TimesheetPeriod[]
  timeEntries         TimeEntry[]
  skills              ConsultantSkill[]
  skillSuggestions    SkillSuggestion[]
  certificates        Certificate[]
  autoApprovalRules   ConsultantAutoApprovalRule[]
  expenses            Expense[]
  personalInfo        ConsultantPersonalInfo?
  companyInfo         ConsultantCompanyInfo?
  address             ConsultantAddress?
  bankAccounts        ConsultantBankAccount[]
  compensations       ConsultantCompensation[]
  benefits            ConsultantBenefit[]
  documents           ConsultantDocument[]
  languages           ConsultantLanguage[]
  educations          ConsultantEducation[]
  cltInfo             ConsultantCltInfo?
  vacations           ConsultantVacation[]
  hourBankEntries     ConsultantHourBankEntry[]
  pjInfo              ConsultantPjInfo?
  legalRepresentative ConsultantLegalRepresentative?
  paymentForecasts    ConsultantPaymentForecast[]
  payments            ConsultantPayment[]
  saleRates           ProjectSaleRate[]
  costRates           ConsultantAllocationCostRate[]
  feedbacks           Feedback[]                     @relation("FeedbackSubject")
  evaluations         Evaluation[]
  developmentPlans    DevelopmentPlan[]
  timeOffs            ConsultantTimeOff[]
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
}

model ConsultantPersonalInfo {
  id               String         @id @default(cuid())
  consultantId     String         @unique
  consultant       Consultant     @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  cpf              String?
  birthDate        DateTime?
  phone            String?
  socialName       String?
  /// Chave de storage da foto (bucket consultant-documents). Nunca uma URL.
  photoStorageKey  String?
  rg               String?
  gender           Gender?
  maritalStatus    MaritalStatus?
  nationality      String?
  personalEmail    String?
  corporateEmail   String?
  mobilePhone      String?
  emergencyPhone   String?
  emergencyContact String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model ConsultantCompanyInfo {
  id                    String     @id @default(cuid())
  consultantId          String     @unique
  consultant            Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  cnpj                  String?
  legalName             String?
  tradeName             String?
  municipalRegistration String?
  stateRegistration     String?
  cnaePrimary           String?
  taxRegime             String?
  providerSnapshot      Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model ConsultantAddress {
  id               String     @id @default(cuid())
  consultantId     String     @unique
  consultant       Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  postalCode       String?
  street           String?
  district         String?
  city             String?
  state            String?
  number           String?
  complement       String?
  providerSnapshot Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model ConsultantBankAccount {
  id             String          @id @default(cuid())
  consultantId   String
  consultant     Consultant      @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  kind           BankAccountKind @default(PRIMARY)
  bankCode       String?
  bankName       String?
  agency         String?
  accountNumber  String?
  accountDigit   String?
  pixKey         String?
  holderDocument String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([consultantId])
}

model ConsultantCompensation {
  id                String                 @id @default(cuid())
  consultantId      String
  consultant        Consultant             @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  contractType      ConsultantContractType
  startsAt          DateTime
  endsAt            DateTime?
  hourlyRate        Decimal?               @db.Decimal(12, 2)
  cltAmount         Decimal?               @db.Decimal(12, 2)
  pjAmount          Decimal?               @db.Decimal(12, 2)
  benefitCardAmount Decimal?               @db.Decimal(12, 2)
  discountRules     Json?
  note              String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([consultantId, startsAt])
}

model ConsultantBenefit {
  id           String      @id @default(cuid())
  consultantId String
  consultant   Consultant  @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  type         BenefitType
  amount       Decimal     @db.Decimal(12, 2)
  startsAt     DateTime
  endsAt       DateTime?
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([consultantId, startsAt])
}

/// Documento anexavel do consultor (o arquivo vive em object storage, bucket
/// `consultant-documents`). Espelha ExpenseAttachment, mas com `type` e
/// cardinalidade 1:N. A regra "um anexo por tipo" e aplicada na Server Action
/// (upsert por consultantId+type), nao no banco, para permitir multiplos OTHER.
model ConsultantDocument {
  id               String                 @id @default(cuid())
  consultantId     String
  consultant       Consultant             @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  type             ConsultantDocumentType
  fileName         String
  contentType      String
  size             Int
  storageBucket    String
  storageKey       String
  uploadedByUserId String?
  uploadedBy       User?                  @relation("ConsultantDocumentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([consultantId, type])
  @@index([uploadedByUserId])
}

/// Idioma do consultor (Competencias). 1:N simples, gerenciado por People.
model ConsultantLanguage {
  id           String        @id @default(cuid())
  consultantId String
  consultant   Consultant    @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  name         String
  level        LanguageLevel
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([consultantId])
}

/// Formacao academica do consultor (Competencias). 1:N, gerenciado por People.
model ConsultantEducation {
  id           String          @id @default(cuid())
  consultantId String
  consultant   Consultant      @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  institution  String
  course       String
  degree       EducationDegree
  startYear    Int?
  endYear      Int?
  completed    Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([consultantId])
}

/// Dados especificos CLT: contratacao + dados trabalhistas (1:1). Visivel
/// quando Consultant.contractType e CLT ou CLT_FLEX.
model ConsultantCltInfo {
  id                 String           @id @default(cuid())
  consultantId       String           @unique
  consultant         Consultant       @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  registrationNumber String?
  pisPasep           String?
  ctpsNumber         String?
  ctpsSeries         String?
  admissionDate      DateTime?
  dismissalDate      DateTime?
  contractKind       CltContractKind?
  workSchedule       String?
  workShift          String?
  union              String?
  registeredRole     String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

/// Ferias do consultor CLT (1:N). Cada linha e um periodo aquisitivo; o
/// historico sao as linhas anteriores. balanceDays e persistido para o
/// historico mas pode ser derivado de entitledDays - takenDays.
model ConsultantVacation {
  id                 String     @id @default(cuid())
  consultantId       String
  consultant         Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  accrualPeriodStart DateTime
  accrualPeriodEnd   DateTime
  entitledDays       Int        @default(30)
  takenDays          Int        @default(0)
  balanceDays        Int        @default(30)
  note               String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([consultantId, accrualPeriodStart])
}

/// Banco de horas (1:N, ledger). Saldo atual = SUM(hours). Positivo = credito
/// (hora extra), negativo = debito (compensacao).
model ConsultantHourBankEntry {
  id           String            @id @default(cuid())
  consultantId String
  consultant   Consultant        @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  occurredAt   DateTime
  kind         HourBankEntryKind
  hours        Decimal           @db.Decimal(6, 2)
  note         String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([consultantId, occurredAt])
}

/// Dados especificos PJ: contratacao + faturamento (1:1). A identidade da
/// empresa (CNPJ, razao social, inscricoes, CNAE, regime) vive em
/// ConsultantCompanyInfo. Visivel quando contractType e PJ ou CLT_FLEX.
model ConsultantPjInfo {
  id                  String       @id @default(cuid())
  consultantId        String       @unique
  consultant          Consultant   @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  contractStart       DateTime?
  contractEnd         DateTime?
  contractTermMonths  Int?
  autoRenew           Boolean      @default(false)
  issuesInvoice       Boolean      @default(true)
  invoiceType         InvoiceType?
  issuingMunicipality String?
  issRate             Decimal?     @db.Decimal(5, 2)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

/// Responsavel legal da empresa PJ (1:1).
model ConsultantLegalRepresentative {
  id           String     @id @default(cuid())
  consultantId String     @unique
  consultant   Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  name         String?
  cpf          String?
  email        String?
  phone        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Client {
  id                String              @id @default(cuid())
  name              String
  document          String?
  contactEmail      String?
  logoUrl           String?
  billingTypeId     String?
  billingType       BillingType?        @relation(fields: [billingTypeId], references: [id], onDelete: SetNull)
  defaultHourlyRate Decimal?            @db.Decimal(12, 2)
  monthlyFee        Decimal?            @db.Decimal(12, 2)
  hourLimit         Decimal?            @db.Decimal(10, 2)
  roundingRule      BillingRoundingRule @default(NONE)
  billingDay        Int?
  dueDay            Int?
  invoiceKind       InvoiceKind         @default(SERVICE)
  municipality      String?
  issRate           Decimal?            @db.Decimal(5, 2)
  taxRules          Json?
  status            ClientStatus        @default(ACTIVE)
  projects          Project[]
  closings          MonthlyClosing[]
  revenueClosings   RevenueClosing[]
  fiscalDocuments   FiscalDocument[]
  feedbacks         Feedback[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([billingTypeId])
}

model BillingType {
  id           String              @id @default(cuid())
  name         String              @unique
  chargeType   BillingChargeType
  roundingRule BillingRoundingRule @default(NONE)
  description  String?
  howItWorks   String?
  example      String?
  active       Boolean             @default(true)
  clients      Client[]
  projects     Project[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Project {
  id                          String                       @id @default(cuid())
  clientId                    String
  client                      Client                       @relation(fields: [clientId], references: [id])
  name                        String
  description                 String?
  status                      ProjectStatus                @default(PROPOSAL)
  startDate                   DateTime
  endDate                     DateTime?
  managerUserId               String?
  billingTypeId               String?
  billingType                 BillingType?                 @relation(fields: [billingTypeId], references: [id], onDelete: SetNull)
  billingConfig               ProjectBillingConfig?
  billingHourlyRate           Decimal?                     @db.Decimal(12, 2)
  budgetHours                 Decimal?                     @db.Decimal(10, 2)
  costCenter                  String?
  allocations                 Allocation[]
  timeEntries                 TimeEntry[]
  closings                    MonthlyClosing[]
  saleRates                   ProjectSaleRate[]
  revenueClosings             RevenueClosing[]
  revenueClosingLines         RevenueClosingLine[]
  consultantPaymentLines      ConsultantPaymentLine[]
  autoApprovalRule            ProjectAutoApprovalRule?
  autoApprovalConsultantRules ConsultantAutoApprovalRule[]
  expenses                    Expense[]
  feedbacks                   Feedback[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt

  @@index([clientId])
  @@index([managerUserId])
  @@index([billingTypeId])
}

/// Regras de faturamento parametrizaveis por projeto, editadas pelo Financeiro.
/// O `chargeType` (comportamento do motor) vem do BillingType; aqui ficam os
/// parametros que o motor de calculo consome (franquia, excedente, fixo, datas,
/// reajuste, retencoes) sem necessidade de alterar o codigo-fonte por contrato.
model ProjectBillingConfig {
  id                    String              @id @default(cuid())
  projectId             String              @unique
  project               Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  periodicity           BillingPeriodicity  @default(MONTHLY)
  roundingRule          BillingRoundingRule @default(NONE)
  fixedAmount           Decimal?            @db.Decimal(12, 2)
  includedHours         Decimal?            @db.Decimal(10, 2)
  overageRate           Decimal?            @db.Decimal(12, 2)
  overageTreatment      OverageTreatment    @default(BILL_EXTRA)
  perConsultantAmount   Decimal?            @db.Decimal(12, 2)
  reimbursableExpenses  Boolean             @default(false)
  reimbursableMarkupPct Decimal?            @db.Decimal(5, 2)
  discountPct           Decimal?            @db.Decimal(5, 2)
  penaltyPct            Decimal?            @db.Decimal(5, 2)
  adjustmentIndex       AdjustmentIndex     @default(NONE)
  adjustmentPct         Decimal?            @db.Decimal(7, 4)
  withholdIss           Boolean             @default(false)
  withholdingPct        Decimal?            @db.Decimal(5, 2)
  closingDay            Int?
  dueDay                Int?
  requireApproval       Boolean             @default(true)
  parameters            Json?
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

model Allocation {
  id                     String                         @id @default(cuid())
  consultantId           String
  consultant             Consultant                     @relation(fields: [consultantId], references: [id])
  projectId              String
  project                Project                        @relation(fields: [projectId], references: [id])
  role                   String
  allocationPercent      Int
  startDate              DateTime
  endDate                DateTime?
  status                 AllocationStatus               @default(PLANNED)
  timeEntries            TimeEntry[]
  expenses               Expense[]
  timesheetDefault       TimesheetDefault?
  saleRates              ProjectSaleRate[]
  costRates              ConsultantAllocationCostRate[]
  consultantPaymentLines ConsultantPaymentLine[]
  allocationSkills       AllocationSkill[]
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt

  @@index([consultantId])
  @@index([projectId])
}

model ProjectSaleRate {
  id           String      @id @default(cuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  consultantId String?
  consultant   Consultant? @relation(fields: [consultantId], references: [id], onDelete: SetNull)
  allocationId String?
  allocation   Allocation? @relation(fields: [allocationId], references: [id], onDelete: SetNull)
  startsAt     DateTime
  endsAt       DateTime?
  hourlyRate   Decimal     @db.Decimal(12, 2)
  currency     String      @default("BRL")
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([projectId, startsAt])
  @@index([consultantId])
  @@index([allocationId])
}

model ConsultantAllocationCostRate {
  id           String     @id @default(cuid())
  consultantId String
  consultant   Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  allocationId String
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Restrict)
  startsAt     DateTime
  endsAt       DateTime?
  hourlyCost   Decimal    @db.Decimal(12, 2)
  currency     String     @default("BRL")
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([consultantId, startsAt])
  @@index([allocationId, startsAt])
}

/// Consultant-maintained weekly default for an active allocation. It powers the
/// "Aplicar padrao da semana" flow without creating automatic hours silently:
/// the consultant explicitly previews/applies the pattern for the selected
/// week. `weekdays` stores ISO weekday numbers (1=Mon ... 7=Sun).
model TimesheetDefault {
  id           String     @id @default(cuid())
  allocationId String     @unique
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  activityType String     @default("WORKDAY")
  hoursPerDay  Decimal    @db.Decimal(5, 2)
  weekdays     Int[]      @default([1, 2, 3, 4, 5])
  billable     Boolean    @default(true)
  description  String?
  // Padrao de horario (formato "HH:mm"). Quando preenchido, alimenta o calculo de
  // horas no relogio de ponto e a comparacao com o "padrao definido" na aprovacao
  // automatica. breakStart/breakEnd nulos = sem pausa.
  startTime    String?
  breakStart   String?
  breakEnd     String?
  endTime      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model TimesheetPeriod {
  id           String                @id @default(cuid())
  consultantId String
  consultant   Consultant            @relation(fields: [consultantId], references: [id])
  startDate    DateTime
  endDate      DateTime
  status       TimesheetPeriodStatus @default(DRAFT)
  submittedAt  DateTime?
  entries      TimeEntry[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([consultantId, startDate, endDate])
}

model TimeEntry {
  id                     String                  @id @default(cuid())
  periodId               String
  period                 TimesheetPeriod         @relation(fields: [periodId], references: [id])
  consultantId           String
  consultant             Consultant              @relation(fields: [consultantId], references: [id])
  projectId              String
  project                Project                 @relation(fields: [projectId], references: [id])
  allocationId           String?
  allocation             Allocation?             @relation(fields: [allocationId], references: [id])
  date                   DateTime
  // `hours` e derivado e persistido a partir dos horarios de ponto
  // (Saida - Inicio - pausa). Mantido como Decimal porque revenue/payment leem
  // diretamente entry.hours. Linhas legadas podem ter horarios nulos.
  hours                  Decimal                 @db.Decimal(5, 2)
  startTime              String?
  breakStart             String?
  breakEnd               String?
  endTime                String?
  activityType           String
  description            String?
  billable               Boolean                 @default(true)
  status                 TimeEntryStatus         @default(DRAFT)
  submittedAt            DateTime?
  revenueClosingLines    RevenueClosingLine[]
  consultantPaymentLines ConsultantPaymentLine[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([periodId])
  @@index([consultantId])
  @@index([projectId])
  @@index([allocationId])
  @@index([consultantId, date, status])
  @@index([status, submittedAt])
  // Global admin/consolidated report: month range across all consultants and
  // projects, without fixing consultantId/projectId. The other indexes lead
  // with consultantId/projectId/status, so a pure date-range filter would seq
  // scan without this single-column index.
  @@index([date])
}

model Approval {
  id             String               @id @default(cuid())
  entityType     ApprovableEntityType
  entityId       String
  approverUserId String?
  approver       User?                @relation("ApprovalApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  status         ApprovalStatus
  comment        String?
  isAutomatic    Boolean              @default(false)
  ruleKey        String?
  createdAt      DateTime             @default(now())

  @@index([entityType, entityId])
  @@index([approverUserId])
}

model Skill {
  id                 String                  @id @default(cuid())
  name               String
  category           String?
  /// Natureza da competencia. Default TECHNICAL para backfill seguro das linhas
  /// existentes (catalogo atual e majoritariamente tecnico); editavel no admin.
  type               SkillType               @default(TECHNICAL)
  status             SkillStatus             @default(ACTIVE)
  consultants        ConsultantSkill[]
  suggestions        SkillSuggestion[]
  allocations        AllocationSkill[]
  competencyItems    CompetencyProfileItem[]
  evaluationAnswers  EvaluationAnswer[]
  developmentActions DevelopmentAction[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@unique([name, category])
}

/// Skill tag attached to a specific project Allocation. It is intentionally
/// isolated from ConsultantSkill: this records which catalog skill the
/// consultant is using ON THIS PROJECT, without touching the consultant's own
/// validated skill profile. Deleting the allocation removes its skill tags
/// (Cascade); catalog skills are protected (Restrict) so a referenced skill
/// cannot be deleted while still tagged on an allocation.
model AllocationSkill {
  id           String      @id @default(cuid())
  allocationId String
  allocation   Allocation  @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  skillId      String
  skill        Skill       @relation(fields: [skillId], references: [id], onDelete: Restrict)
  level        SkillLevel?
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([allocationId, skillId])
  @@index([allocationId])
  @@index([skillId])
}

model ConsultantSkill {
  id               String                   @id @default(cuid())
  consultantId     String
  consultant       Consultant               @relation(fields: [consultantId], references: [id])
  skillId          String
  skill            Skill                    @relation(fields: [skillId], references: [id])
  level            SkillLevel
  yearsExperience  Decimal?                 @db.Decimal(4, 1)
  lastUsedAt       DateTime?
  validationStatus ValidationStatus         @default(PENDING)
  evidences        SkillEvidence[]
  history          ConsultantSkillHistory[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([consultantId, skillId])
  @@index([skillId])
}

/// Human-reviewed skill suggestion generated from weekly activity evidence.
/// The assistant proposes; the consultant decides. Existing catalog skills can
/// be accepted into ConsultantSkill as PENDING validation. Unknown skills stay
/// as suggestions and do not become ACTIVE catalog rows automatically.
model SkillSuggestion {
  id                String                @id @default(cuid())
  consultantId      String
  consultant        Consultant            @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  weekStart         DateTime
  weekEnd           DateTime
  skillId           String?
  skill             Skill?                @relation(fields: [skillId], references: [id], onDelete: SetNull)
  suggestedName     String
  suggestedCategory String?
  suggestedLevel    SkillLevel            @default(INTERMEDIATE)
  evidenceSummary   String?
  sourceEntryIds    String[]              @default([])
  status            SkillSuggestionStatus @default(PENDING)
  decidedAt         DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([consultantId, weekStart, suggestedName])
  @@index([consultantId, weekStart])
  @@index([skillId])
  @@index([status])
}

/// Perfil de competencias esperado (nivel requerido) por senioridade, cargo ou
/// area. Onda 0 (Talentos): base do gap analysis (requerido x atual). O alvo do
/// perfil e identificado por scope + referenceKey (chave logica livre, sem FK a
/// uma tabela de cargos ainda inexistente). Soft delete via status reusando o
/// enum SkillStatus (ACTIVE/INACTIVE), padrao das entidades operacionais.
model CompetencyProfile {
  id           String                  @id @default(cuid())
  name         String
  scope        CompetencyScope
  referenceKey String
  status       SkillStatus             @default(ACTIVE)
  items        CompetencyProfileItem[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([scope, referenceKey])
  @@index([status])
}

/// Item de um perfil de competencias: o nivel requerido (SkillLevel) de uma
/// skill dentro do perfil. Cascade no perfil (itens morrem com o perfil); a skill
/// e protegida (Restrict) para nao apagar um item de catalogo ainda referenciado.
/// Unico por (profileId, skillId): uma skill aparece no maximo uma vez por perfil.
model CompetencyProfileItem {
  id            String            @id @default(cuid())
  profileId     String
  profile       CompetencyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skillId       String
  skill         Skill             @relation(fields: [skillId], references: [id], onDelete: Restrict)
  requiredLevel SkillLevel
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([profileId, skillId])
  @@index([profileId])
  @@index([skillId])
}

/// Evidencia que sustenta o nivel atual de uma competencia do consultor. Cascade
/// no ConsultantSkill (a evidencia perde sentido sem a skill do consultor).
/// sourceId aponta para o registro de origem (ex.: feedbackId, certificateId)
/// quando aplicavel; e mantido como String solta para nao acoplar a entidades de
/// ondas futuras (avaliacao, feedback) que ainda nao existem.
model SkillEvidence {
  id                String              @id @default(cuid())
  consultantSkillId String
  consultantSkill   ConsultantSkill     @relation(fields: [consultantSkillId], references: [id], onDelete: Cascade)
  sourceType        SkillEvidenceSource
  sourceId          String?
  note              String?
  createdAt         DateTime            @default(now())

  @@index([consultantSkillId])
}

/// Historico de evolucao de nivel de uma competencia do consultor (append-only).
/// Uma linha por mudanca de nivel, preservando a trilha de auditoria leve da skill.
/// Cascade no ConsultantSkill; changedByUser opcional (SetNull) para manter o
/// historico mesmo se o usuario que alterou for removido.
model ConsultantSkillHistory {
  id                String          @id @default(cuid())
  consultantSkillId String
  consultantSkill   ConsultantSkill @relation(fields: [consultantSkillId], references: [id], onDelete: Cascade)
  level             SkillLevel
  changedByUserId   String?
  changedByUser     User?           @relation("SkillHistoryChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)
  reason            String?
  createdAt         DateTime        @default(now())

  @@index([consultantSkillId])
}

/// Feedback continuo sobre um consultor (EP15), ancorado opcionalmente a um
/// projeto/cliente reais. Forma o historico que alimenta avaliacao e score.
/// Cascade no consultor (o feedback nao faz sentido sem o avaliado); autor e
/// SetNull para preservar o registro se o usuario for removido. visibility
/// (PRIVATE/SHARED) e a regra LGPD aplicada no servidor: PRIVATE so e visto por
/// autor + PEOPLE + gestor responsavel. Os campos de voz/IA (audioStorageKey,
/// transcription, transcriptionStatus) sao apoio para o incremento atras de
/// feature flag; sem logica no banco.
model Feedback {
  id                  String              @id @default(cuid())
  subjectConsultantId String
  subjectConsultant   Consultant          @relation("FeedbackSubject", fields: [subjectConsultantId], references: [id], onDelete: Cascade)
  authorUserId        String?
  author              User?               @relation("FeedbackAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  type                FeedbackType
  source              FeedbackSource
  visibility          FeedbackVisibility  @default(PRIVATE)
  body                String
  relatedProjectId    String?
  relatedProject      Project?            @relation(fields: [relatedProjectId], references: [id], onDelete: SetNull)
  relatedClientId     String?
  relatedClient       Client?             @relation(fields: [relatedClientId], references: [id], onDelete: SetNull)
  audioStorageKey     String?
  transcription       String?
  transcriptionStatus TranscriptionStatus @default(NONE)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([subjectConsultantId])
  @@index([subjectConsultantId, createdAt])
}

/// Ciclo de avaliacao 90/180/360 (EP16). createdBy e SetNull para preservar o
/// ciclo se o criador for removido. As Evaluation morrem com o ciclo (Cascade).
model EvaluationCycle {
  id               String                @id @default(cuid())
  name             String
  type             EvaluationType
  periodStart      DateTime
  periodEnd        DateTime
  status           EvaluationCycleStatus @default(DRAFT)
  createdByUserId  String?
  createdBy        User?                 @relation("EvaluationCycleCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  evaluations      Evaluation[]
  developmentPlans DevelopmentPlan[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

/// A avaliacao de um consultor dentro de um ciclo. Unica por (ciclo, consultor).
/// Cascade no ciclo e no consultor (a avaliacao nao existe sem ambos).
model Evaluation {
  id                  String               @id @default(cuid())
  cycleId             String
  cycle               EvaluationCycle      @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  subjectConsultantId String
  subjectConsultant   Consultant           @relation(fields: [subjectConsultantId], references: [id], onDelete: Cascade)
  status              EvaluationStatus     @default(PENDING)
  responses           EvaluationResponse[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([cycleId, subjectConsultantId])
}

/// Uma resposta de avaliador dentro de uma avaliacao. raterUserId e SetNull e
/// opcional (avaliador-cliente sem usuario, ou usuario removido preserva a
/// resposta). relationship distingue SELF/MANAGER/PEER/CLIENT/SUBORDINATE.
model EvaluationResponse {
  id           String                 @id @default(cuid())
  evaluationId String
  evaluation   Evaluation             @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  raterUserId  String?
  rater        User?                  @relation("EvaluationResponseRater", fields: [raterUserId], references: [id], onDelete: SetNull)
  relationship EvaluationRelationship
  status       EvaluationStatus       @default(PENDING)
  submittedAt  DateTime?
  answers      EvaluationAnswer[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([evaluationId, relationship])
  @@index([evaluationId])
}

/// Nota por competencia dentro de uma resposta. Cascade na resposta; a skill e
/// protegida (Restrict) por ser catalogo referenciado. score 1-5 validado na
/// app. Unico por (resposta, skill): uma nota por competencia por avaliador.
model EvaluationAnswer {
  id         String             @id @default(cuid())
  responseId String
  response   EvaluationResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill              @relation(fields: [skillId], references: [id], onDelete: Restrict)
  score      Int
  comment    String?
  createdAt  DateTime           @default(now())

  @@unique([responseId, skillId])
  @@index([responseId])
}

/// Plano de Desenvolvimento Individual (EP17). Cascade no consultor; cycleId
/// opcional (SetNull) liga o PDI ao ciclo de avaliacao que o originou; owner e
/// SetNull. Soft delete operacional via status (CANCELLED).
model DevelopmentPlan {
  id           String                @id @default(cuid())
  consultantId String
  consultant   Consultant            @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  cycleId      String?
  cycle        EvaluationCycle?      @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  ownerUserId  String?
  owner        User?                 @relation("DevelopmentPlanOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  status       DevelopmentPlanStatus @default(ACTIVE)
  periodStart  DateTime
  periodEnd    DateTime
  actions      DevelopmentAction[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([consultantId])
}

/// Acao concreta de um PDI. Cascade no plano; targetSkill opcional (SetNull) e a
/// skill alvo da acao, derivada do gap. evidenceNote registra a comprovacao da
/// conclusao (futuro: vinculo com Certificate/Universidade/Expense).
model DevelopmentAction {
  id            String                  @id @default(cuid())
  planId        String
  plan          DevelopmentPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  type          DevelopmentActionType
  targetSkillId String?
  targetSkill   Skill?                  @relation(fields: [targetSkillId], references: [id], onDelete: SetNull)
  description   String
  dueAt         DateTime?
  status        DevelopmentActionStatus @default(PLANNED)
  evidenceNote  String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([planId])
}

/// Ausencia agendada com datas concretas de gozo (ferias/licenca/outros).
/// Complementa ConsultantVacation (que e o ledger de periodo aquisitivo, NAO
/// alterado) e e a fonte real do heatmap de disponibilidade (EP11): substitui o
/// proxy da Onda 0. Cascade no consultor. status permite soft cancel.
model ConsultantTimeOff {
  id           String        @id @default(cuid())
  consultantId String
  consultant   Consultant    @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  kind         TimeOffKind
  startDate    DateTime
  endDate      DateTime
  status       TimeOffStatus @default(PLANNED)
  note         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([consultantId, startDate])
}

model Certificate {
  id            String           @id @default(cuid())
  consultantId  String
  consultant    Consultant       @relation(fields: [consultantId], references: [id])
  name          String
  issuer        String
  issuedAt      DateTime
  expiresAt     DateTime?
  credentialId  String?
  credentialUrl String?
  fileUrl       String?
  status        ValidationStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([consultantId])
}

model MonthlyClosing {
  id             String               @id @default(cuid())
  clientId       String
  client         Client               @relation(fields: [clientId], references: [id])
  projectId      String
  project        Project              @relation(fields: [projectId], references: [id])
  month          Int
  year           Int
  status         MonthlyClosingStatus @default(OPEN)
  totalHours     Decimal              @db.Decimal(10, 2)
  totalAmount    Decimal              @db.Decimal(12, 2)
  closedByUserId String?
  closedAt       DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([projectId, month, year])
  @@index([clientId])
}

model RevenueClosing {
  id               String               @id @default(cuid())
  clientId         String
  client           Client               @relation(fields: [clientId], references: [id])
  projectId        String?
  project          Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  month            Int
  year             Int
  status           RevenueClosingStatus @default(OPEN)
  totalHours       Decimal              @default(0) @db.Decimal(10, 2)
  grossAmount      Decimal              @default(0) @db.Decimal(12, 2)
  adjustmentAmount Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal              @default(0) @db.Decimal(12, 2)
  notes            String?
  closedByUserId   String?
  closedBy         User?                @relation("RevenueClosingCloser", fields: [closedByUserId], references: [id], onDelete: SetNull)
  closedAt         DateTime?
  lines            RevenueClosingLine[]
  fiscalDocuments  FiscalDocument[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([clientId, projectId, month, year])
  @@index([clientId])
  @@index([projectId])
  @@index([status])
}

model RevenueClosingLine {
  id               String         @id @default(cuid())
  revenueClosingId String
  revenueClosing   RevenueClosing @relation(fields: [revenueClosingId], references: [id], onDelete: Cascade)
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id])
  timeEntryId      String?
  timeEntry        TimeEntry?     @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  description      String?
  hours            Decimal        @default(0) @db.Decimal(10, 2)
  unitRate         Decimal        @default(0) @db.Decimal(12, 2)
  amount           Decimal        @default(0) @db.Decimal(12, 2)
  createdAt        DateTime       @default(now())

  @@index([revenueClosingId])
  @@index([projectId])
  @@index([timeEntryId])
}

model FiscalDocument {
  id                String                  @id @default(cuid())
  kind              FiscalDocumentKind      @default(NFSE)
  status            FiscalDocumentStatus    @default(DRAFT)
  clientId          String
  client            Client                  @relation(fields: [clientId], references: [id])
  revenueClosingId  String?
  revenueClosing    RevenueClosing?         @relation(fields: [revenueClosingId], references: [id], onDelete: SetNull)
  provider          IntegrationProviderKind @default(SAO_PAULO_NFSE)
  invoiceNumber     String?
  protocol          String?
  xmlStorageBucket  String?
  xmlStorageKey     String?
  pdfStorageBucket  String?
  pdfStorageKey     String?
  errorMessage      String?
  validatedByUserId String?
  validatedBy       User?                   @relation("FiscalDocumentValidator", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  issuedAt          DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@unique([provider, invoiceNumber])
  @@index([clientId])
  @@index([revenueClosingId])
  @@index([status])
  @@index([invoiceNumber])
