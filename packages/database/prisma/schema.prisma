generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RoleName {
  ADMIN
  CONSULTANT
  PROJECT_MANAGER
  AREA_MANAGER
  FINANCE
  PEOPLE
  SALES
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ConsultantStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum Seniority {
  INTERN
  JUNIOR
  MID_LEVEL
  SENIOR
  SPECIALIST
  PRINCIPAL
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum SkillStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  PROPOSAL
  ACTIVE
  PAUSED
  CLOSED
}

enum AllocationStatus {
  ACTIVE
  PLANNED
  ENDED
  CANCELLED
  INACTIVE
}

enum TimesheetPeriodStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CLOSED
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CLOSED
}

enum SkillLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
  SPECIALIST
}

enum ValidationStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum SkillSuggestionStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

enum ApprovalStatus {
  APPROVED
  REJECTED
}

enum ApprovableEntityType {
  TIME_ENTRY
  CONSULTANT_SKILL
  CERTIFICATE
  EXPENSE
}

/// Single status chain for expenses (no separate payment enum). Flow:
/// DRAFT -> SUBMITTED -> MANAGER_APPROVED -> FINANCE_APPROVED ->
/// PAYMENT_SCHEDULED -> PAID, with MANAGER_REJECTED / FINANCE_REJECTED as
/// rejection branches. PAID is the only terminal status.
enum ExpenseStatus {
  DRAFT
  SUBMITTED
  MANAGER_APPROVED
  MANAGER_REJECTED
  FINANCE_APPROVED
  FINANCE_REJECTED
  PAYMENT_SCHEDULED
  PAID
}

/// Tipo/categoria de um lancamento de despesa. Lista fixa de dominio hoje;
/// Postgres permite adicionar valores via ALTER TYPE ... ADD VALUE (vide
/// AutomationEmailType). Vire tabela de referencia apenas se a categoria passar
/// a ter atributos proprios (ex.: reembolsavel por padrao, conta contabil).
enum ExpenseCategory {
  MILEAGE_REIMBURSEMENT
  AIR_TICKET
  BUS_TICKET
  CERTIFICATION
  ACCOUNTING
  RIDE_SHARE
  COURSES_TRAINING
  LODGING
  POSTAGE
  MEALS
  PERIPHERALS
  TOLL
  PARKING
}

enum MonthlyClosingStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum AutoApprovalExceptionType {
  ANY_HOURS
  WEEKEND
}

enum AutomationEmailType {
  MISSING_TIMESHEET_REPORT
  // Fase G: pre-fatura enviada ao cliente (uma por RevenueClosing + competencia).
  PRE_INVOICE
  // Fase H: NFS-e emitida enviada ao cliente (uma por FiscalDocument + competencia).
  NFSE_ISSUED
}

enum EmailDeliveryStatus {
  SENT
  FAILED
}

/// Catalogo de modelos de cobranca. Os quatro primeiros (HOURLY, MONTHLY,
/// CONSULTANT_HOURLY, FIXED) sao os valores originais e NAO devem ser
/// renomeados/removidos: CONSULTANT_HOURLY e base de NF na Fase D. Postgres so
/// permite adicionar valores ao enum (ALTER TYPE ... ADD VALUE), entao a ordem
/// de declaracao reflete a evolucao historica.
enum BillingChargeType {
  HOURLY
  MONTHLY
  CONSULTANT_HOURLY
  FIXED
  HOURLY_PLUS_FIXED
  HOUR_PACKAGE
  PER_ALLOCATED_CONSULTANT
  PER_PROJECT
  MILESTONE
  PER_SPRINT
  TIME_AND_MATERIAL
  ON_DEMAND
  SUBSCRIPTION
  PAY_AS_YOU_GO
  SUCCESS_FEE
  MIXED
}

enum BillingRoundingRule {
  NONE
  NEAREST_15_MINUTES
  NEAREST_30_MINUTES
  NEAREST_HOUR
  CEIL_15_MINUTES
  CEIL_30_MINUTES
  CEIL_HOUR
}

/// Periodicidade de faturamento configurada por projeto (motor parametrizavel).
enum BillingPeriodicity {
  MONTHLY
  BIWEEKLY
  WEEKLY
  PER_EVENT
}

/// Tratamento de horas excedentes (alem da franquia/pacote contratado).
enum OverageTreatment {
  BILL_EXTRA
  BLOCK_AT_LIMIT
  INCLUDE_FREE
  CARRY_OVER
}

/// Indice de reajuste contratual. Apenas FIXED multiplica automaticamente neste
/// ciclo; IPCA/IGPM/CDI ficam marcados para tratamento futuro (sem fonte externa).
enum AdjustmentIndex {
  NONE
  IPCA
  IGPM
  CDI
  FIXED
}

enum InvoiceKind {
  SERVICE
  PRODUCT
}

enum RevenueClosingStatus {
  OPEN
  IN_REVIEW
  READY_TO_CLOSE
  CLOSED
  INVOICED
  CANCELLED
}

enum ConsultantContractType {
  CLT
  PJ
  CLT_FLEX
}

enum BankAccountKind {
  CLT
  PJ
  PRIMARY
}

enum BenefitType {
  MEAL_VOUCHER
  FOOD_VOUCHER
  TRANSPORTATION_VOUCHER
  BENEFIT_CARD
  OTHER
}

enum ConsultantPaymentStatus {
  OPEN
  WAITING_FOR_INVOICE
  INVOICE_RECEIVED
  INVOICE_VALIDATED
  APPROVED_FOR_PAYMENT
  SENT_TO_BANK
  PROCESSED
  PAID
  CANCELLED
}

enum FiscalDocumentStatus {
  DRAFT
  REQUESTED
  ISSUED
  FAILED
  CANCELLED
}

enum FiscalDocumentKind {
  NFSE
  PRODUCT_INVOICE
}

enum IntegrationProviderKind {
  CNPJ
  CEP
  ENTRA_ID
  SAO_PAULO_NFSE
  EMAIL
  STORAGE
  BANK
  ERP
}

enum IntegrationEventStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

model User {
  id                         String                      @id @default(cuid())
  name                       String
  email                      String                      @unique
  status                     UserStatus                  @default(ACTIVE)
  // Local credentials provider (Round 5). Nullable: Entra users and not-yet
  // accepted invitations have no password. Format is the self-describing
  // scrypt string `scrypt$N$r$p$<saltB64url>$<hashB64url>` (see auth-foundation
  // 11.3). Never store or log the plaintext password.
  passwordHash               String?
  emailVerifiedAt            DateTime?
  lastLoginAt                DateTime?
  mustChangePassword         Boolean                     @default(false)
  roles                      UserRole[]
  consultant                 Consultant?
  auditEvents                AuditEvent[]                @relation("AuditActor")
  approvals                  Approval[]                  @relation("ApprovalApprover")
  uploadedExpenseAttachments ExpenseAttachment[]         @relation("ExpenseAttachmentUploader")
  closedRevenueClosings      RevenueClosing[]            @relation("RevenueClosingCloser")
  validatedFiscalDocuments   FiscalDocument[]            @relation("FiscalDocumentValidator")
  paymentForecastsCreated    ConsultantPaymentForecast[] @relation("PaymentForecastCreator")
  consultantPaymentsApproved ConsultantPayment[]         @relation("ConsultantPaymentApprover")
  // Invitations this user created (actor side) and the invitation that created
  // this user on acceptance (at most one).
  invitationsSent            UserInvitation[]            @relation("InvitedBy")
  invitationCreated          UserInvitation?             @relation("CreatedUser")
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
}

model Role {
  id        String     @id @default(cuid())
  name      RoleName   @unique
  users     UserRole[]
  createdAt DateTime   @default(now())
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

/// Invitation-only onboarding (Round 5). There is no public sign-up: a user
/// enters the platform solely by accepting an invitation created by an ADMIN.
/// The invite token is a high-entropy secret delivered once; only its sha256
/// digest is stored in `tokenHash` (@unique), never the plaintext token.
/// `roles` carries the RoleName enum array to grant on acceptance, kept in the
/// row (no join table) since the role set is small and static for the MVP and
/// is written/read atomically with the invitation. Acceptance is single-use
/// + TTL-bound (`expiresAt`); status transitions and the
/// re-hash/lookup/validate flow are enforced in Server Actions.
model UserInvitation {
  id              String           @id @default(cuid())
  // Normalized to lowercase in the application layer before persisting.
  email           String
  name            String
  // sha256 digest of the plaintext token (hex/base64url). Plaintext is never
  // stored. @unique enforces single active digest per token.
  tokenHash       String           @unique
  status          InvitationStatus @default(PENDING)
  // Roles to grant when the invitation is accepted. Native Postgres enum array.
  roles           RoleName[]
  expiresAt       DateTime
  acceptedAt      DateTime?
  // Actor who created the invitation. Restrict so an admin with open invites
  // cannot be hard-deleted without first resolving them (audit integrity).
  invitedByUserId String
  invitedBy       User             @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  // Populated on acceptance with the created/activated user. SetNull keeps the
  // invitation history if that user is later removed.
  createdUserId   String?          @unique
  createdUser     User?            @relation("CreatedUser", fields: [createdUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([email])
  @@index([status])
}

model Consultant {
  id                     String                         @id @default(cuid())
  userId                 String?                        @unique
  user                   User?                          @relation(fields: [userId], references: [id])
  name                   String
  email                  String                         @unique
  jobTitle               String?
  seniority              Seniority
  area                   String?
  status                 ConsultantStatus               @default(ACTIVE)
  hourlyCost             Decimal?                       @db.Decimal(12, 2)
  allocations            Allocation[]
  periods                TimesheetPeriod[]
  timeEntries            TimeEntry[]
  skills                 ConsultantSkill[]
  skillSuggestions       SkillSuggestion[]
  certificates           Certificate[]
  autoApprovalExceptions AutoApprovalException[]
  expenses               Expense[]
  personalInfo           ConsultantPersonalInfo?
  companyInfo            ConsultantCompanyInfo?
  address                ConsultantAddress?
  bankAccounts           ConsultantBankAccount[]
  compensations          ConsultantCompensation[]
  benefits               ConsultantBenefit[]
  paymentForecasts       ConsultantPaymentForecast[]
  payments               ConsultantPayment[]
  saleRates              ProjectSaleRate[]
  costRates              ConsultantAllocationCostRate[]
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
}

model ConsultantPersonalInfo {
  id           String     @id @default(cuid())
  consultantId String     @unique
  consultant   Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  cpf          String?
  birthDate    DateTime?
  phone        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ConsultantCompanyInfo {
  id                    String     @id @default(cuid())
  consultantId          String     @unique
  consultant            Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  cnpj                  String?
  legalName             String?
  tradeName             String?
  municipalRegistration String?
  taxRegime             String?
  providerSnapshot      Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model ConsultantAddress {
  id               String     @id @default(cuid())
  consultantId     String     @unique
  consultant       Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  postalCode       String?
  street           String?
  district         String?
  city             String?
  state            String?
  number           String?
  complement       String?
  providerSnapshot Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model ConsultantBankAccount {
  id             String          @id @default(cuid())
  consultantId   String
  consultant     Consultant      @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  kind           BankAccountKind @default(PRIMARY)
  bankCode       String?
  bankName       String?
  agency         String?
  accountNumber  String?
  accountDigit   String?
  pixKey         String?
  holderDocument String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([consultantId])
}

model ConsultantCompensation {
  id                String                 @id @default(cuid())
  consultantId      String
  consultant        Consultant             @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  contractType      ConsultantContractType
  startsAt          DateTime
  endsAt            DateTime?
  hourlyRate        Decimal?               @db.Decimal(12, 2)
  cltAmount         Decimal?               @db.Decimal(12, 2)
  pjAmount          Decimal?               @db.Decimal(12, 2)
  benefitCardAmount Decimal?               @db.Decimal(12, 2)
  discountRules     Json?
  note              String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([consultantId, startsAt])
}

model ConsultantBenefit {
  id           String      @id @default(cuid())
  consultantId String
  consultant   Consultant  @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  type         BenefitType
  amount       Decimal     @db.Decimal(12, 2)
  startsAt     DateTime
  endsAt       DateTime?
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([consultantId, startsAt])
}

model Client {
  id                String              @id @default(cuid())
  name              String
  document          String?
  contactEmail      String?
  logoUrl           String?
  billingTypeId     String?
  billingType       BillingType?        @relation(fields: [billingTypeId], references: [id], onDelete: SetNull)
  defaultHourlyRate Decimal?            @db.Decimal(12, 2)
  monthlyFee        Decimal?            @db.Decimal(12, 2)
  hourLimit         Decimal?            @db.Decimal(10, 2)
  roundingRule      BillingRoundingRule @default(NONE)
  billingDay        Int?
  dueDay            Int?
  invoiceKind       InvoiceKind         @default(SERVICE)
  municipality      String?
  issRate           Decimal?            @db.Decimal(5, 2)
  taxRules          Json?
  status            ClientStatus        @default(ACTIVE)
  projects          Project[]
  closings          MonthlyClosing[]
  revenueClosings   RevenueClosing[]
  fiscalDocuments   FiscalDocument[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([billingTypeId])
}

model BillingType {
  id           String              @id @default(cuid())
  name         String              @unique
  chargeType   BillingChargeType
  roundingRule BillingRoundingRule @default(NONE)
  description  String?
  howItWorks   String?
  example      String?
  active       Boolean             @default(true)
  clients      Client[]
  projects     Project[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model Project {
  id                     String                  @id @default(cuid())
  clientId               String
  client                 Client                  @relation(fields: [clientId], references: [id])
  name                   String
  description            String?
  status                 ProjectStatus           @default(PROPOSAL)
  startDate              DateTime
  endDate                DateTime?
  managerUserId          String?
  billingTypeId          String?
  billingType            BillingType?            @relation(fields: [billingTypeId], references: [id], onDelete: SetNull)
  billingConfig          ProjectBillingConfig?
  billingHourlyRate      Decimal?                @db.Decimal(12, 2)
  budgetHours            Decimal?                @db.Decimal(10, 2)
  costCenter             String?
  allocations            Allocation[]
  timeEntries            TimeEntry[]
  closings               MonthlyClosing[]
  saleRates              ProjectSaleRate[]
  revenueClosings        RevenueClosing[]
  revenueClosingLines    RevenueClosingLine[]
  consultantPaymentLines ConsultantPaymentLine[]
  autoApprovalExceptions AutoApprovalException[]
  expenses               Expense[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([clientId])
  @@index([managerUserId])
  @@index([billingTypeId])
}

/// Regras de faturamento parametrizaveis por projeto, editadas pelo Financeiro.
/// O `chargeType` (comportamento do motor) vem do BillingType; aqui ficam os
/// parametros que o motor de calculo consome (franquia, excedente, fixo, datas,
/// reajuste, retencoes) sem necessidade de alterar o codigo-fonte por contrato.
model ProjectBillingConfig {
  id                    String              @id @default(cuid())
  projectId             String              @unique
  project               Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  periodicity           BillingPeriodicity  @default(MONTHLY)
  roundingRule          BillingRoundingRule @default(NONE)
  fixedAmount           Decimal?            @db.Decimal(12, 2)
  includedHours         Decimal?            @db.Decimal(10, 2)
  overageRate           Decimal?            @db.Decimal(12, 2)
  overageTreatment      OverageTreatment    @default(BILL_EXTRA)
  perConsultantAmount   Decimal?            @db.Decimal(12, 2)
  reimbursableExpenses  Boolean             @default(false)
  reimbursableMarkupPct Decimal?            @db.Decimal(5, 2)
  discountPct           Decimal?            @db.Decimal(5, 2)
  penaltyPct            Decimal?            @db.Decimal(5, 2)
  adjustmentIndex       AdjustmentIndex     @default(NONE)
  adjustmentPct         Decimal?            @db.Decimal(7, 4)
  withholdIss           Boolean             @default(false)
  withholdingPct        Decimal?            @db.Decimal(5, 2)
  closingDay            Int?
  dueDay                Int?
  requireApproval       Boolean             @default(true)
  parameters            Json?
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

model Allocation {
  id                     String                         @id @default(cuid())
  consultantId           String
  consultant             Consultant                     @relation(fields: [consultantId], references: [id])
  projectId              String
  project                Project                        @relation(fields: [projectId], references: [id])
  role                   String
  allocationPercent      Int
  startDate              DateTime
  endDate                DateTime?
  status                 AllocationStatus               @default(PLANNED)
  timeEntries            TimeEntry[]
  expenses               Expense[]
  timesheetDefault       TimesheetDefault?
  saleRates              ProjectSaleRate[]
  costRates              ConsultantAllocationCostRate[]
  consultantPaymentLines ConsultantPaymentLine[]
  allocationSkills       AllocationSkill[]
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt

  @@index([consultantId])
  @@index([projectId])
}

model ProjectSaleRate {
  id           String      @id @default(cuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  consultantId String?
  consultant   Consultant? @relation(fields: [consultantId], references: [id], onDelete: SetNull)
  allocationId String?
  allocation   Allocation? @relation(fields: [allocationId], references: [id], onDelete: SetNull)
  startsAt     DateTime
  endsAt       DateTime?
  hourlyRate   Decimal     @db.Decimal(12, 2)
  currency     String      @default("BRL")
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([projectId, startsAt])
  @@index([consultantId])
  @@index([allocationId])
}

model ConsultantAllocationCostRate {
  id           String     @id @default(cuid())
  consultantId String
  consultant   Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  allocationId String
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Restrict)
  startsAt     DateTime
  endsAt       DateTime?
  hourlyCost   Decimal    @db.Decimal(12, 2)
  currency     String     @default("BRL")
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([consultantId, startsAt])
  @@index([allocationId, startsAt])
}

/// Consultant-maintained weekly default for an active allocation. It powers the
/// "Aplicar padrao da semana" flow without creating automatic hours silently:
/// the consultant explicitly previews/applies the pattern for the selected
/// week. `weekdays` stores ISO weekday numbers (1=Mon ... 7=Sun).
model TimesheetDefault {
  id           String     @id @default(cuid())
  allocationId String     @unique
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  activityType String     @default("WORKDAY")
  hoursPerDay  Decimal    @db.Decimal(5, 2)
  weekdays     Int[]      @default([1, 2, 3, 4, 5])
  billable     Boolean    @default(true)
  description  String?
  // Padrao de horario (formato "HH:mm"). Quando preenchido, alimenta o calculo de
  // horas no relogio de ponto e a comparacao com o "padrao definido" na aprovacao
  // automatica. breakStart/breakEnd nulos = sem pausa.
  startTime    String?
  breakStart   String?
  breakEnd     String?
  endTime      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model TimesheetPeriod {
  id           String                @id @default(cuid())
  consultantId String
  consultant   Consultant            @relation(fields: [consultantId], references: [id])
  startDate    DateTime
  endDate      DateTime
  status       TimesheetPeriodStatus @default(DRAFT)
  submittedAt  DateTime?
  entries      TimeEntry[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([consultantId, startDate, endDate])
}

model TimeEntry {
  id                     String                  @id @default(cuid())
  periodId               String
  period                 TimesheetPeriod         @relation(fields: [periodId], references: [id])
  consultantId           String
  consultant             Consultant              @relation(fields: [consultantId], references: [id])
  projectId              String
  project                Project                 @relation(fields: [projectId], references: [id])
  allocationId           String?
  allocation             Allocation?             @relation(fields: [allocationId], references: [id])
  date                   DateTime
  // `hours` e derivado e persistido a partir dos horarios de ponto
  // (Saida - Inicio - pausa). Mantido como Decimal porque revenue/payment leem
  // diretamente entry.hours. Linhas legadas podem ter horarios nulos.
  hours                  Decimal                 @db.Decimal(5, 2)
  startTime              String?
  breakStart             String?
  breakEnd               String?
  endTime                String?
  activityType           String
  description            String?
  billable               Boolean                 @default(true)
  status                 TimeEntryStatus         @default(DRAFT)
  submittedAt            DateTime?
  revenueClosingLines    RevenueClosingLine[]
  consultantPaymentLines ConsultantPaymentLine[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([periodId])
  @@index([consultantId])
  @@index([projectId])
  @@index([allocationId])
  @@index([consultantId, date, status])
  @@index([status, submittedAt])
  // Global admin/consolidated report: month range across all consultants and
  // projects, without fixing consultantId/projectId. The other indexes lead
  // with consultantId/projectId/status, so a pure date-range filter would seq
  // scan without this single-column index.
  @@index([date])
}

model Approval {
  id             String               @id @default(cuid())
  entityType     ApprovableEntityType
  entityId       String
  approverUserId String?
  approver       User?                @relation("ApprovalApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  status         ApprovalStatus
  comment        String?
  isAutomatic    Boolean              @default(false)
  ruleKey        String?
  createdAt      DateTime             @default(now())

  @@index([entityType, entityId])
  @@index([approverUserId])
}

model Skill {
  id          String            @id @default(cuid())
  name        String
  category    String?
  status      SkillStatus       @default(ACTIVE)
  consultants ConsultantSkill[]
  suggestions SkillSuggestion[]
  allocations AllocationSkill[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([name, category])
}

/// Skill tag attached to a specific project Allocation. It is intentionally
/// isolated from ConsultantSkill: this records which catalog skill the
/// consultant is using ON THIS PROJECT, without touching the consultant's own
/// validated skill profile. Deleting the allocation removes its skill tags
/// (Cascade); catalog skills are protected (Restrict) so a referenced skill
/// cannot be deleted while still tagged on an allocation.
model AllocationSkill {
  id           String      @id @default(cuid())
  allocationId String
  allocation   Allocation  @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  skillId      String
  skill        Skill       @relation(fields: [skillId], references: [id], onDelete: Restrict)
  level        SkillLevel?
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([allocationId, skillId])
  @@index([allocationId])
  @@index([skillId])
}

model ConsultantSkill {
  id               String           @id @default(cuid())
  consultantId     String
  consultant       Consultant       @relation(fields: [consultantId], references: [id])
  skillId          String
  skill            Skill            @relation(fields: [skillId], references: [id])
  level            SkillLevel
  yearsExperience  Decimal?         @db.Decimal(4, 1)
  lastUsedAt       DateTime?
  validationStatus ValidationStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([consultantId, skillId])
  @@index([skillId])
}

/// Human-reviewed skill suggestion generated from weekly activity evidence.
/// The assistant proposes; the consultant decides. Existing catalog skills can
/// be accepted into ConsultantSkill as PENDING validation. Unknown skills stay
/// as suggestions and do not become ACTIVE catalog rows automatically.
model SkillSuggestion {
  id                String                @id @default(cuid())
  consultantId      String
  consultant        Consultant            @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  weekStart         DateTime
  weekEnd           DateTime
  skillId           String?
  skill             Skill?                @relation(fields: [skillId], references: [id], onDelete: SetNull)
  suggestedName     String
  suggestedCategory String?
  suggestedLevel    SkillLevel            @default(INTERMEDIATE)
  evidenceSummary   String?
  sourceEntryIds    String[]              @default([])
  status            SkillSuggestionStatus @default(PENDING)
  decidedAt         DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([consultantId, weekStart, suggestedName])
  @@index([consultantId, weekStart])
  @@index([skillId])
  @@index([status])
}

model Certificate {
  id            String           @id @default(cuid())
  consultantId  String
  consultant    Consultant       @relation(fields: [consultantId], references: [id])
  name          String
  issuer        String
  issuedAt      DateTime
  expiresAt     DateTime?
  credentialId  String?
  credentialUrl String?
  fileUrl       String?
  status        ValidationStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([consultantId])
}

model MonthlyClosing {
  id             String               @id @default(cuid())
  clientId       String
  client         Client               @relation(fields: [clientId], references: [id])
  projectId      String
  project        Project              @relation(fields: [projectId], references: [id])
  month          Int
  year           Int
  status         MonthlyClosingStatus @default(OPEN)
  totalHours     Decimal              @db.Decimal(10, 2)
  totalAmount    Decimal              @db.Decimal(12, 2)
  closedByUserId String?
  closedAt       DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([projectId, month, year])
  @@index([clientId])
}

model RevenueClosing {
  id               String               @id @default(cuid())
  clientId         String
  client           Client               @relation(fields: [clientId], references: [id])
  projectId        String?
  project          Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  month            Int
  year             Int
  status           RevenueClosingStatus @default(OPEN)
  totalHours       Decimal              @default(0) @db.Decimal(10, 2)
  grossAmount      Decimal              @default(0) @db.Decimal(12, 2)
  adjustmentAmount Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal              @default(0) @db.Decimal(12, 2)
  notes            String?
  closedByUserId   String?
  closedBy         User?                @relation("RevenueClosingCloser", fields: [closedByUserId], references: [id], onDelete: SetNull)
  closedAt         DateTime?
  lines            RevenueClosingLine[]
  fiscalDocuments  FiscalDocument[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([clientId, projectId, month, year])
  @@index([clientId])
  @@index([projectId])
  @@index([status])
}

model RevenueClosingLine {
  id               String         @id @default(cuid())
  revenueClosingId String
  revenueClosing   RevenueClosing @relation(fields: [revenueClosingId], references: [id], onDelete: Cascade)
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id])
  timeEntryId      String?
  timeEntry        TimeEntry?     @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  description      String?
  hours            Decimal        @default(0) @db.Decimal(10, 2)
  unitRate         Decimal        @default(0) @db.Decimal(12, 2)
  amount           Decimal        @default(0) @db.Decimal(12, 2)
  createdAt        DateTime       @default(now())

  @@index([revenueClosingId])
  @@index([projectId])
  @@index([timeEntryId])
}

model FiscalDocument {
  id                String                  @id @default(cuid())
  kind              FiscalDocumentKind      @default(NFSE)
  status            FiscalDocumentStatus    @default(DRAFT)
  clientId          String
  client            Client                  @relation(fields: [clientId], references: [id])
  revenueClosingId  String?
  revenueClosing    RevenueClosing?         @relation(fields: [revenueClosingId], references: [id], onDelete: SetNull)
  provider          IntegrationProviderKind @default(SAO_PAULO_NFSE)
  invoiceNumber     String?
  protocol          String?
  xmlStorageBucket  String?
  xmlStorageKey     String?
  pdfStorageBucket  String?
  pdfStorageKey     String?
  errorMessage      String?
  validatedByUserId String?
  validatedBy       User?                   @relation("FiscalDocumentValidator", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  issuedAt          DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@unique([provider, invoiceNumber])
  @@index([clientId])
  @@index([revenueClosingId])
  @@index([status])
  @@index([invoiceNumber])
}

model ConsultantPaymentForecast {
  id                 String              @id @default(cuid())
  consultantId       String?
  consultant         Consultant?         @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  closingMonth       Int
  closingYear        Int
  responseDeadlineAt DateTime
  expectedPaymentAt  DateTime
  createdByUserId    String?
  createdBy          User?               @relation("PaymentForecastCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  payments           ConsultantPayment[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([consultantId])
  @@index([closingYear, closingMonth])
}

model ConsultantPayment {
  id                 String                     @id @default(cuid())
  consultantId       String
  consultant         Consultant                 @relation(fields: [consultantId], references: [id])
  forecastId         String?
  forecast           ConsultantPaymentForecast? @relation(fields: [forecastId], references: [id], onDelete: SetNull)
  month              Int
  year               Int
  contractType       ConsultantContractType
  status             ConsultantPaymentStatus    @default(OPEN)
  cltNetAmount       Decimal                    @default(0) @db.Decimal(12, 2)
  pjAmount           Decimal                    @default(0) @db.Decimal(12, 2)
  benefitAmount      Decimal                    @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal                    @default(0) @db.Decimal(12, 2)
  expectedPaymentAt  DateTime?
  confirmedPaidAt    DateTime?
  invoiceReceivedAt  DateTime?
  invoiceValidatedAt DateTime?
  approvedByUserId   String?
  approvedBy         User?                      @relation("ConsultantPaymentApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt         DateTime?
  lines              ConsultantPaymentLine[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@unique([consultantId, month, year])
  @@index([forecastId])
  @@index([status])
  @@index([year, month])
}

model ConsultantPaymentLine {
  id                  String            @id @default(cuid())
  consultantPaymentId String
  consultantPayment   ConsultantPayment @relation(fields: [consultantPaymentId], references: [id], onDelete: Cascade)
  projectId           String?
  project             Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  allocationId        String?
  allocation          Allocation?       @relation(fields: [allocationId], references: [id], onDelete: SetNull)
  timeEntryId         String?
  timeEntry           TimeEntry?        @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  description         String
  hours               Decimal           @default(0) @db.Decimal(10, 2)
  unitRate            Decimal           @default(0) @db.Decimal(12, 2)
  amount              Decimal           @default(0) @db.Decimal(12, 2)
  createdAt           DateTime          @default(now())

  @@index([consultantPaymentId])
  @@index([projectId])
  @@index([allocationId])
  @@index([timeEntryId])
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  entityType  String
  entityId    String
  action      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

/// Configurable list of (consultant, project) exceptions to the default
/// auto-approval rule. ANY_HOURS skips the daily 8h total; WEEKEND allows
/// Saturday/Sunday entries. Rules live in the DB so they change without deploy.
model AutoApprovalException {
  id           String                    @id @default(cuid())
  consultantId String
  consultant   Consultant                @relation(fields: [consultantId], references: [id])
  projectId    String
  project      Project                   @relation(fields: [projectId], references: [id])
  type         AutoApprovalExceptionType
  active       Boolean                   @default(true)
  note         String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@unique([consultantId, projectId, type])
  @@index([projectId])
}

/// Singleton tunables for the automation engine. Always read/written via
/// upsert on id = "default".
model AutomationConfig {
  id                   String   @id @default("default")
  autoApprovalEnabled  Boolean  @default(true)
  requiredDailyMinutes Int      @default(480)
  approvalDelayMinutes Int      @default(5)
  reportRecipientEmail String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Delivery log for automated emails. The unique (type, referenceKey) is the
/// idempotency key: a given report period is sent at most once.
model AutomationEmailLog {
  id           String              @id @default(cuid())
  type         AutomationEmailType
  referenceKey String
  recipient    String
  status       EmailDeliveryStatus
  error        String?
  meta         Json?
  createdAt    DateTime            @default(now())

  @@unique([type, referenceKey])
  @@index([createdAt])
}

model IntegrationEvent {
  id             String                  @id @default(cuid())
  provider       IntegrationProviderKind
  operation      String
  status         IntegrationEventStatus  @default(PENDING)
  entityType     String?
  entityId       String?
  idempotencyKey String?
  requestMeta    Json?
  responseMeta   Json?
  error          String?
  attemptedAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@unique([provider, idempotencyKey])
  @@index([provider, status])
  @@index([entityType, entityId])
  @@index([createdAt])
}

/// Consultant expense tied to a project (and the active allocation that
/// authorized it). `date` is stored as UTC midnight (date-only semantics,
/// same convention as TimeEntry.date). Status transitions, RBAC and the
/// "active allocation covering the expense date" rule are enforced in
/// Server Actions; sensitive transitions emit AuditEvent + Approval rows.
model Expense {
  id            String             @id @default(cuid())
  consultantId  String
  consultant    Consultant         @relation(fields: [consultantId], references: [id])
  projectId     String
  project       Project            @relation(fields: [projectId], references: [id])
  allocationId  String?
  allocation    Allocation?        @relation(fields: [allocationId], references: [id])
  date          DateTime
  amount        Decimal            @db.Decimal(12, 2)
  description   String
  invoiceNumber String?
  /// Categoria do lancamento. Nullable para back-compat com Expenses
  /// pre-existentes; novos lancamentos exigem categoria via Zod no servidor.
  category      ExpenseCategory?
  /// Chave de agrupamento por NF/lote (cuid gerado no formulario). Permite
  /// "uma descricao para varias despesas" sem entidade pai: o form cria N
  /// linhas Expense numa transacao compartilhando description, invoiceNumber e
  /// groupId. A UI agrupa por groupId; invoiceNumber permanece dado fiscal.
  groupId       String?
  status        ExpenseStatus      @default(DRAFT)
  submittedAt   DateTime?
  attachment    ExpenseAttachment?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([consultantId])
  @@index([projectId])
  @@index([allocationId])
  @@index([status, submittedAt])
  @@index([consultantId, date])
  @@index([consultantId, groupId])
  // Global finance/consolidated report: month range across all consultants and
  // projects (mirrors TimeEntry.date). Leading columns of the other indexes are
  // consultantId/projectId/status, so a pure date-range filter needs this.
  @@index([date])
}

/// Receipt metadata for an expense (file itself lives in object storage,
/// bucket `expense-receipts`). Separate model (1:1 today) so evolving to
/// multiple attachments per expense is a relation change, not a rewrite.
/// Cascade delete: removing a DRAFT expense also removes the metadata row.
model ExpenseAttachment {
  id               String   @id @default(cuid())
  expenseId        String   @unique
  expense          Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  fileName         String
  contentType      String
  size             Int
  storageBucket    String
  storageKey       String
  uploadedByUserId String?
  uploadedBy       User?    @relation("ExpenseAttachmentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([uploadedByUserId])
}
