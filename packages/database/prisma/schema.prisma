enum CltContractKind {
  INDEFINITE
  FIXED_TERM
  INTERNSHIP
  APPRENTICESHIP
}

/// Tipo de lancamento no banco de horas: credito (extra), debito (compensacao)
/// ou ajuste manual. O saldo e a soma de `hours` (positivo = credito).
