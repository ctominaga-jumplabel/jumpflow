generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RoleName {
  ADMIN
  CONSULTANT
  PROJECT_MANAGER
  AREA_MANAGER
  FINANCE
  PEOPLE
  SALES
}

enum ConsultantStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum Seniority {
  INTERN
  JUNIOR
  MID_LEVEL
  SENIOR
  SPECIALIST
  PRINCIPAL
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum SkillStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  PROPOSAL
  ACTIVE
  PAUSED
  CLOSED
}

enum AllocationStatus {
  ACTIVE
  PLANNED
  ENDED
  CANCELLED
}

enum TimesheetPeriodStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CLOSED
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CLOSED
}

enum SkillLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
  SPECIALIST
}

enum ValidationStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum ApprovalStatus {
  APPROVED
  REJECTED
}

enum ApprovableEntityType {
  TIME_ENTRY
  CONSULTANT_SKILL
  CERTIFICATE
  EXPENSE
}

/// Single status chain for expenses (no separate payment enum). Flow:
/// DRAFT -> SUBMITTED -> MANAGER_APPROVED -> FINANCE_APPROVED ->
/// PAYMENT_SCHEDULED -> PAID, with MANAGER_REJECTED / FINANCE_REJECTED as
/// rejection branches. PAID is the only terminal status.
enum ExpenseStatus {
  DRAFT
  SUBMITTED
  MANAGER_APPROVED
  MANAGER_REJECTED
  FINANCE_APPROVED
  FINANCE_REJECTED
  PAYMENT_SCHEDULED
  PAID
}

enum MonthlyClosingStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum AutoApprovalExceptionType {
  ANY_HOURS
  WEEKEND
}

enum AutomationEmailType {
  MISSING_TIMESHEET_REPORT
}

enum EmailDeliveryStatus {
  SENT
  FAILED
}

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  status      UserStatus   @default(ACTIVE)
  roles       UserRole[]
  consultant  Consultant?
  auditEvents AuditEvent[] @relation("AuditActor")
  approvals   Approval[]   @relation("ApprovalApprover")
  uploadedExpenseAttachments ExpenseAttachment[] @relation("ExpenseAttachmentUploader")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Role {
  id        String     @id @default(cuid())
  name      RoleName   @unique
  users     UserRole[]
  createdAt DateTime   @default(now())
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Consultant {
  id          String             @id @default(cuid())
  userId      String?            @unique
  user        User?              @relation(fields: [userId], references: [id])
  name        String
  email       String             @unique
  jobTitle    String?
  seniority   Seniority
  area        String?
  status      ConsultantStatus   @default(ACTIVE)
  hourlyCost  Decimal?           @db.Decimal(12, 2)
  allocations Allocation[]
  periods     TimesheetPeriod[]
  timeEntries TimeEntry[]
  skills      ConsultantSkill[]
  certificates Certificate[]
  autoApprovalExceptions AutoApprovalException[]
  expenses    Expense[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model Client {
  id        String       @id @default(cuid())
  name      String
  document  String?
  status    ClientStatus @default(ACTIVE)
  projects  Project[]
  closings  MonthlyClosing[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Project {
  id                String           @id @default(cuid())
  clientId          String
  client            Client           @relation(fields: [clientId], references: [id])
  name              String
  description       String?
  status            ProjectStatus    @default(PROPOSAL)
  startDate         DateTime
  endDate           DateTime?
  managerUserId     String?
  billingHourlyRate Decimal?         @db.Decimal(12, 2)
  budgetHours       Decimal?         @db.Decimal(10, 2)
  costCenter        String?
  allocations       Allocation[]
  timeEntries       TimeEntry[]
  closings          MonthlyClosing[]
  autoApprovalExceptions AutoApprovalException[]
  expenses          Expense[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([clientId])
  @@index([managerUserId])
}

model Allocation {
  id                String           @id @default(cuid())
  consultantId      String
  consultant        Consultant       @relation(fields: [consultantId], references: [id])
  projectId         String
  project           Project          @relation(fields: [projectId], references: [id])
  role              String
  allocationPercent Int
  startDate         DateTime
  endDate           DateTime?
  status            AllocationStatus @default(PLANNED)
  timeEntries       TimeEntry[]
  expenses          Expense[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([consultantId])
  @@index([projectId])
}

model TimesheetPeriod {
  id           String                 @id @default(cuid())
  consultantId String
  consultant   Consultant             @relation(fields: [consultantId], references: [id])
  startDate    DateTime
  endDate      DateTime
  status       TimesheetPeriodStatus  @default(DRAFT)
  submittedAt  DateTime?
  entries      TimeEntry[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([consultantId, startDate, endDate])
}

model TimeEntry {
  id           String          @id @default(cuid())
  periodId     String
  period       TimesheetPeriod @relation(fields: [periodId], references: [id])
  consultantId String
  consultant   Consultant      @relation(fields: [consultantId], references: [id])
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id])
  allocationId String?
  allocation   Allocation?     @relation(fields: [allocationId], references: [id])
  date         DateTime
  hours        Decimal         @db.Decimal(5, 2)
  activityType String
  description  String?
  billable     Boolean         @default(true)
  status       TimeEntryStatus @default(DRAFT)
  submittedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([periodId])
  @@index([consultantId])
  @@index([projectId])
  @@index([allocationId])
  @@index([consultantId, date, status])
  @@index([status, submittedAt])
  // Global admin/consolidated report: month range across all consultants and
  // projects, without fixing consultantId/projectId. The other indexes lead
  // with consultantId/projectId/status, so a pure date-range filter would seq
  // scan without this single-column index.
  @@index([date])
}

model Approval {
  id             String               @id @default(cuid())
  entityType     ApprovableEntityType
  entityId       String
  approverUserId String?
  approver       User?                @relation("ApprovalApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  status         ApprovalStatus
  comment        String?
  isAutomatic    Boolean              @default(false)
  ruleKey        String?
  createdAt      DateTime             @default(now())

  @@index([entityType, entityId])
  @@index([approverUserId])
}

model Skill {
  id          String            @id @default(cuid())
  name        String
  category    String?
  status      SkillStatus       @default(ACTIVE)
  consultants ConsultantSkill[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([name, category])
}

model ConsultantSkill {
  id              String           @id @default(cuid())
  consultantId    String
  consultant      Consultant       @relation(fields: [consultantId], references: [id])
  skillId         String
  skill           Skill            @relation(fields: [skillId], references: [id])
  level           SkillLevel
  yearsExperience Decimal?         @db.Decimal(4, 1)
  lastUsedAt      DateTime?
  validationStatus ValidationStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([consultantId, skillId])
  @@index([skillId])
}

model Certificate {
  id           String           @id @default(cuid())
  consultantId String
  consultant   Consultant       @relation(fields: [consultantId], references: [id])
  name         String
  issuer       String
  issuedAt     DateTime
  expiresAt    DateTime?
  credentialId String?
  credentialUrl String?
  fileUrl      String?
  status       ValidationStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([consultantId])
}

model MonthlyClosing {
  id             String               @id @default(cuid())
  clientId       String
  client         Client               @relation(fields: [clientId], references: [id])
  projectId      String
  project        Project              @relation(fields: [projectId], references: [id])
  month          Int
  year           Int
  status         MonthlyClosingStatus @default(OPEN)
  totalHours     Decimal              @db.Decimal(10, 2)
  totalAmount    Decimal              @db.Decimal(12, 2)
  closedByUserId String?
  closedAt       DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([projectId, month, year])
  @@index([clientId])
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  entityType  String
  entityId    String
  action      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

/// Configurable list of (consultant, project) exceptions to the default
/// auto-approval rule. ANY_HOURS skips the daily 8h total; WEEKEND allows
/// Saturday/Sunday entries. Rules live in the DB so they change without deploy.
model AutoApprovalException {
  id           String                    @id @default(cuid())
  consultantId String
  consultant   Consultant                @relation(fields: [consultantId], references: [id])
  projectId    String
  project      Project                   @relation(fields: [projectId], references: [id])
  type         AutoApprovalExceptionType
  active       Boolean                   @default(true)
  note         String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@unique([consultantId, projectId, type])
  @@index([projectId])
}

/// Singleton tunables for the automation engine. Always read/written via
/// upsert on id = "default".
model AutomationConfig {
  id                   String   @id @default("default")
  autoApprovalEnabled  Boolean  @default(true)
  requiredDailyMinutes Int      @default(480)
  approvalDelayMinutes Int      @default(5)
  reportRecipientEmail String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Delivery log for automated emails. The unique (type, referenceKey) is the
/// idempotency key: a given report period is sent at most once.
model AutomationEmailLog {
  id           String              @id @default(cuid())
  type         AutomationEmailType
  referenceKey String
  recipient    String
  status       EmailDeliveryStatus
  error        String?
  meta         Json?
  createdAt    DateTime            @default(now())

  @@unique([type, referenceKey])
  @@index([createdAt])
}

/// Consultant expense tied to a project (and the active allocation that
/// authorized it). `date` is stored as UTC midnight (date-only semantics,
/// same convention as TimeEntry.date). Status transitions, RBAC and the
/// "active allocation covering the expense date" rule are enforced in
/// Server Actions; sensitive transitions emit AuditEvent + Approval rows.
model Expense {
  id            String             @id @default(cuid())
  consultantId  String
  consultant    Consultant         @relation(fields: [consultantId], references: [id])
  projectId     String
  project       Project            @relation(fields: [projectId], references: [id])
  allocationId  String?
  allocation    Allocation?        @relation(fields: [allocationId], references: [id])
  date          DateTime
  amount        Decimal            @db.Decimal(12, 2)
  description   String
  invoiceNumber String?
  status        ExpenseStatus      @default(DRAFT)
  submittedAt   DateTime?
  attachment    ExpenseAttachment?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([consultantId])
  @@index([projectId])
  @@index([allocationId])
  @@index([status, submittedAt])
  @@index([consultantId, date])
  // Global finance/consolidated report: month range across all consultants and
  // projects (mirrors TimeEntry.date). Leading columns of the other indexes are
  // consultantId/projectId/status, so a pure date-range filter needs this.
  @@index([date])
}

/// Receipt metadata for an expense (file itself lives in object storage,
/// bucket `expense-receipts`). Separate model (1:1 today) so evolving to
/// multiple attachments per expense is a relation change, not a rewrite.
/// Cascade delete: removing a DRAFT expense also removes the metadata row.
model ExpenseAttachment {
  id               String   @id @default(cuid())
  expenseId        String   @unique
  expense          Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  fileName         String
  contentType      String
  size             Int
  storageBucket    String
  storageKey       String
  uploadedByUserId String?
  uploadedBy       User?    @relation("ExpenseAttachmentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([uploadedByUserId])
}
