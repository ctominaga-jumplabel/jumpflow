generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum RoleName {
  ADMIN
  CONSULTANT
  PROJECT_MANAGER
  AREA_MANAGER
  FINANCE
  PEOPLE
  SALES
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ConsultantStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum Seniority {
  INTERN
  JUNIOR
  MID_LEVEL
  SENIOR
  SPECIALIST
  PRINCIPAL
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum SkillStatus {
  ACTIVE
  INACTIVE
}

/// Natureza da competencia: tecnica (hard skill) ou comportamental (soft skill).
/// Onda 0 (Talentos): habilita o filtro tecnica/comportamental na matriz. Linhas
/// existentes recebem TECHNICAL no backfill, pois o catalogo atual e tecnico.
enum SkillType {
  TECHNICAL
  BEHAVIORAL
}

/// Escopo de um perfil de competencias esperado (nivel requerido). O perfil e
/// associado a uma referencia logica via referenceKey: senioridade (ex.: SENIOR),
/// cargo/role (ex.: TECH_LEAD) ou area (ex.: DATA). Mantido como chave livre para
/// nao acoplar a uma tabela de cargos que ainda nao existe no MVP.
enum CompetencyScope {
  SENIORITY
  ROLE
  AREA
}

/// Origem de uma evidencia de competencia do consultor. Aponta para o tipo de
/// registro que sustenta o nivel atual; sourceId guarda o id do registro de
/// origem (ex.: feedbackId, certificateId) quando aplicavel.
enum SkillEvidenceSource {
  FEEDBACK
  EVALUATION
  CERTIFICATE
  PROJECT
  MANUAL
}

/// Tipo do feedback continuo (EP15). PRAISE/RECOGNITION sao positivos,
/// GUIDANCE e orientacao construtiva, CONCERN sinaliza ponto de atencao.
enum FeedbackType {
  PRAISE
  GUIDANCE
  RECOGNITION
  CONCERN
}

/// Origem de quem da o feedback: equipe interna, cliente atendido ou par (peer).
enum FeedbackSource {
  INTERNAL
  CLIENT
  PEER
}

/// Visibilidade do feedback (LGPD). SHARED e visivel ao avaliado; PRIVATE fica
/// restrito a autor + PEOPLE + gestor responsavel (regra aplicada no servidor).
enum FeedbackVisibility {
  PRIVATE
  SHARED
}

/// Estado da transcricao de audio do feedback por voz (incremento atras de
/// feature flag). Apenas coluna de apoio; a logica de transcricao vive fora do
/// banco. NONE = feedback sem audio.
enum TranscriptionStatus {
  NONE
  PENDING
  DONE
  FAILED
}

/// Tipo do ciclo de avaliacao (EP16): autoavaliacao (90), avaliacao do gestor
/// somada a autoavaliacao (180) ou avaliacao completa multi-fonte (360).
enum EvaluationType {
  SELF_90
  MANAGER_180
  FULL_360
}

/// Ciclo de avaliacao. Transicoes validas DRAFT -> OPEN -> CLOSED aplicadas no
/// servidor; nao retrocede de CLOSED.
enum EvaluationCycleStatus {
  DRAFT
  OPEN
  CLOSED
}

/// Progresso de uma avaliacao/resposta (reusado por Evaluation e
/// EvaluationResponse): PENDING -> IN_PROGRESS -> COMPLETED.
enum EvaluationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

/// Relacao do avaliador com o avaliado no ciclo 360. SELF e a autoavaliacao;
/// CLIENT e o avaliador-cliente com acesso restrito ao proprio formulario.
enum EvaluationRelationship {
  SELF
  MANAGER
  PEER
  CLIENT
  SUBORDINATE
}

/// Estado do Plano de Desenvolvimento Individual (EP17). Soft delete operacional
/// via CANCELLED; COMPLETED quando todas as acoes sao concluidas.
enum DevelopmentPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

/// Tipo de acao de desenvolvimento no PDI. Liga-se opcionalmente a uma skill alvo
/// (targetSkillId) e, no futuro, a cursos da Universidade e Certificate.
enum DevelopmentActionType {
  TRAINING
  MENTORSHIP
  CERTIFICATION
  PROJECT
  READING
}

/// Estado de uma acao do PDI: PLANNED -> IN_PROGRESS -> DONE (ou CANCELLED).
enum DevelopmentActionStatus {
  PLANNED
  IN_PROGRESS
  DONE
  CANCELLED
}

/// Tipo de ausencia agendada (datas concretas de gozo). VACATION e o gozo de
/// ferias; complementa ConsultantVacation (ledger de periodo aquisitivo) e e a
/// fonte real do heatmap de disponibilidade (EP11).
enum TimeOffKind {
  VACATION
  LEAVE
  OTHER
}

/// Estado de uma ausencia (Onda D: vira fluxo com aprovacao). REQUESTED (pedido
/// do consultor) -> CONFIRMED (aprovada, gera TimeEntry) ou REJECTED (negada).
/// PLANNED mantido para lancamentos diretos por People/gestor (sem pedido);
/// CANCELLED encerra. Transicoes aplicadas no servidor.
enum TimeOffStatus {
  PLANNED
  REQUESTED
  CONFIRMED
  REJECTED
  CANCELLED
}

/// Tipo de pesquisa interna (EP 7.1). CLIMATE = clima organizacional, NPS = eNPS
/// (recomendacao), SATISFACTION = satisfacao pontual, LEADERSHIP = avaliacao de
/// lideranca, PULSE = pulso curto recorrente.
enum SurveyType {
  CLIMATE
  NPS
  SATISFACTION
  LEADERSHIP
  PULSE
}

/// Estado da pesquisa. DRAFT -> OPEN (coletando respostas) -> CLOSED (encerrada).
/// Nao retrocede de CLOSED; transicoes aplicadas no servidor.
enum SurveyStatus {
  DRAFT
  OPEN
  CLOSED
}

/// Tipo de questao da pesquisa. SCALE = escala numerica (ex.: 1-5), NPS = escala
/// 0-10 de recomendacao, TEXT = resposta aberta, CHOICE = escolha entre options.
enum SurveyQuestionType {
  SCALE
  NPS
  TEXT
  CHOICE
}

/// Estado do convite de resposta. PENDING = ainda nao respondeu, ANSWERED =
/// respondeu (sem ligar a resposta a identidade), EXPIRED = janela encerrada.
/// Este enum + SurveyInvitation sao o UNICO mecanismo de "quem respondeu".
enum SurveyInvitationStatus {
  PENDING
  ANSWERED
  EXPIRED
}

/// Escopo de um objetivo/OKR (EP 7.2). O alvo logico e identificado por
/// referenceKey (chave livre) e/ou pelas FKs opcionais consultantId/projectId.
/// AREA usa referenceKey (ex.: 'DATA'); COMPANY normalmente ignora referenceKey.
enum ObjectiveScope {
  CONSULTANT
  PROJECT
  AREA
  COMPANY
}

/// Estado de um objetivo. DRAFT -> ACTIVE -> COMPLETED, ou CANCELLED (soft
/// delete operacional). Transicoes aplicadas no servidor.
enum ObjectiveStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

/// Unidade da metrica de um Key Result. CURRENCY usa Decimal(14,2) em BRL;
/// PERCENT trabalha em pontos percentuais; BOOLEAN usa 0/1 em current/target.
enum KeyResultMetric {
  NUMBER
  PERCENT
  CURRENCY
  BOOLEAN
}

/// Estado de um item de catalogo da Universidade Jump (trilha/curso). Soft delete
/// operacional via INACTIVE, padrao das entidades de catalogo.
enum LearningStatus {
  ACTIVE
  INACTIVE
}

/// Estado da matricula do consultor em um curso (EP 7.3). ENROLLED -> IN_PROGRESS
/// -> COMPLETED, ou CANCELLED. Pontos/ranking de gamificacao sao DERIVADOS das
/// matriculas COMPLETED; nao ha tabela de pontos.
enum EnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProjectStatus {
  PROPOSAL
  ACTIVE
  PAUSED
  CLOSED
}

/// Condicao/arranjo de pagamento do cliente no projeto (PRAZO de recebimento).
/// NAO se confunde com BillingChargeType, que descreve o MODELO de cobranca
/// (como o valor e apurado). Aqui e QUANDO/EM QUANTAS PARCELAS o cliente paga.
enum ProjectPaymentType {
  ONE_TIME
  INSTALLMENTS
  MONTHLY
  ON_MILESTONE
}

/// Situacao de cada recebimento previsto do cliente (lado receita).
enum ReceivableStatus {
  FORECAST
  RECEIVED
  CANCELLED
}

enum AllocationStatus {
  ACTIVE
  PLANNED
  ENDED
  CANCELLED
  INACTIVE
}

enum TimesheetPeriodStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CLOSED
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CLOSED
}

enum SkillLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
  SPECIALIST
}

enum ValidationStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum SkillSuggestionStatus {
  PENDING
  ACCEPTED
  DISMISSED
}

enum ApprovalStatus {
  APPROVED
  REJECTED
}

enum ApprovableEntityType {
  TIME_ENTRY
  CONSULTANT_SKILL
  CERTIFICATE
  EXPENSE
  TIME_OFF
}

/// Single status chain for expenses (no separate payment enum). Flow:
/// DRAFT -> SUBMITTED -> MANAGER_APPROVED -> FINANCE_APPROVED ->
/// PAYMENT_SCHEDULED -> PAID, with MANAGER_REJECTED / FINANCE_REJECTED as
/// rejection branches. PAID is the only terminal status.
enum ExpenseStatus {
  DRAFT
  SUBMITTED
  MANAGER_APPROVED
  MANAGER_REJECTED
  FINANCE_APPROVED
  FINANCE_REJECTED
  PAYMENT_SCHEDULED
  PAID
}

/// Tipo/categoria de um lancamento de despesa. Lista fixa de dominio hoje;
/// Postgres permite adicionar valores via ALTER TYPE ... ADD VALUE (vide
/// AutomationEmailType). Vire tabela de referencia apenas se a categoria passar
/// a ter atributos proprios (ex.: reembolsavel por padrao, conta contabil).
enum ExpenseCategory {
  MILEAGE_REIMBURSEMENT
  AIR_TICKET
  BUS_TICKET
  CERTIFICATION
  ACCOUNTING
  RIDE_SHARE
  COURSES_TRAINING
  LODGING
  POSTAGE
  MEALS
  PERIPHERALS
  TOLL
  PARKING
}

enum MonthlyClosingStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum AutomationEmailType {
  MISSING_TIMESHEET_REPORT
  // Fase G: pre-fatura enviada ao cliente (uma por RevenueClosing + competencia).
  PRE_INVOICE
  // Fase H: NFS-e emitida enviada ao cliente (uma por FiscalDocument + competencia).
  NFSE_ISSUED
  // Motor de notificacoes: envio operacional generico (liberacao, alertas, etc.).
  // O referenceKey codifica evento + destinatario para idempotencia por pessoa.
  NOTIFICATION
}

enum EmailDeliveryStatus {
  SENT
  FAILED
}

/// Catalogo de modelos de cobranca. Os quatro primeiros (HOURLY, MONTHLY,
/// CONSULTANT_HOURLY, FIXED) sao os valores originais e NAO devem ser
/// renomeados/removidos: CONSULTANT_HOURLY e base de NF na Fase D. Postgres so
/// permite adicionar valores ao enum (ALTER TYPE ... ADD VALUE), entao a ordem
/// de declaracao reflete a evolucao historica.
enum BillingChargeType {
  HOURLY
  MONTHLY
  CONSULTANT_HOURLY
  FIXED
  HOURLY_PLUS_FIXED
  HOUR_PACKAGE
  PER_ALLOCATED_CONSULTANT
  PER_PROJECT
  MILESTONE
  PER_SPRINT
  TIME_AND_MATERIAL
  ON_DEMAND
  SUBSCRIPTION
  PAY_AS_YOU_GO
  SUCCESS_FEE
  MIXED
}

enum BillingRoundingRule {
  NONE
  NEAREST_15_MINUTES
  NEAREST_30_MINUTES
  NEAREST_HOUR
  CEIL_15_MINUTES
  CEIL_30_MINUTES
  CEIL_HOUR
}

/// Periodicidade de faturamento configurada por projeto (motor parametrizavel).
enum BillingPeriodicity {
  MONTHLY
  BIWEEKLY
  WEEKLY
  PER_EVENT
}

/// Tratamento de horas excedentes (alem da franquia/pacote contratado).
enum OverageTreatment {
  BILL_EXTRA
  BLOCK_AT_LIMIT
  INCLUDE_FREE
  CARRY_OVER
}

/// A quais vinculos a regra de hora extra (% e excedente) se aplica.
enum OvertimeAppliesTo {
