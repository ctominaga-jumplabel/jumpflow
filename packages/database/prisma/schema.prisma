model Project {
  id                          String                       @id @default(cuid())
  clientId                    String
  client                      Client                       @relation(fields: [clientId], references: [id])
  name                        String
  description                 String?
  status                      ProjectStatus                @default(PROPOSAL)
  startDate                   DateTime
  endDate                     DateTime?
  managerUserId               String?
  billingTypeId               String?
  billingType                 BillingType?                 @relation(fields: [billingTypeId], references: [id], onDelete: SetNull)
  billingConfig               ProjectBillingConfig?
  billingHourlyRate           Decimal?                     @db.Decimal(12, 2)
  budgetHours                 Decimal?                     @db.Decimal(10, 2)
  costCenter                  String?
  /// Referencia do contrato comercial (numero/identificador). ADR 0002 Fase 1:
  /// presenca = contrato vinculado; ausencia dispara alerta COMMERCIAL_CONTRACT_MISSING.
  commercialContractRef       String?
  /// Condicao de pagamento do cliente (prazo/arranjo). Opcional; complementa o
  /// BillingChargeType (modelo de cobranca) sem substitui-lo.
  paymentType                 ProjectPaymentType?
  /// Flag INFORMATIVA de termo de aceite. Nao bloqueia nenhuma operacao; apenas
  /// registra a exigencia e, quando aplicavel, quando/por quem foi aceito.
  /// acceptanceTermAcceptedByUserId segue o padrao de managerUserId/closedByUserId:
  /// referencia solta ao User (sem FK), para nao acoplar auditoria a User.
  requiresAcceptanceTerm      Boolean                      @default(false)
  acceptanceTermAcceptedAt    DateTime?
  acceptanceTermAcceptedByUserId String?
  allocations                 Allocation[]
  timeEntries                 TimeEntry[]
  closings                    MonthlyClosing[]
  operationClosings           OperationClosing[]
  saleRates                   ProjectSaleRate[]
  revenueClosings             RevenueClosing[]
  revenueClosingLines         RevenueClosingLine[]
  consultantPaymentLines      ConsultantPaymentLine[]
  autoApprovalRule            ProjectAutoApprovalRule?
  autoApprovalConsultantRules ConsultantAutoApprovalRule[]
  expenses                    Expense[]
  onCallEntries               OnCallEntry[]
  feedbacks                   Feedback[]
  objectives                  Objective[]
  // Checkpoint/1-on-1 + inteligencia (Melhoria #4). Todas as FKs sao opcionais e
  // onDelete SetNull: o registro pode existir sem projeto e sobrevive a remocao dele.
  checkpoints                 Checkpoint[]
  opportunities               Opportunity[]
  cases                       Case[]
  holidays                    HolidayProject[]
  receivables                 ProjectReceivableSchedule[]
  adHocPayments               ConsultantAdHocPayment[]
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt

  @@index([clientId])
  @@index([managerUserId])
  @@index([billingTypeId])
}

/// Agenda de recebimentos previstos do cliente (lado receita). Complementa
/// BillingType/ProjectBillingConfig (como se COBRA) com a previsao de QUANDO e
/// QUANTO entra: parcelas com data, valor e situacao. Dados financeiros; leitura
/// restrita a perfis autorizados e alteracoes sensiveis devem gerar AuditEvent.
model ProjectReceivableSchedule {
  id        String           @id @default(cuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dueAt     DateTime         @db.Date
  amount    Decimal          @db.Decimal(12, 2)
  label     String
  status    ReceivableStatus @default(FORECAST)
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([projectId, dueAt])
}

/// Regras de faturamento parametrizaveis por projeto, editadas pelo Financeiro.
/// O `chargeType` (comportamento do motor) vem do BillingType; aqui ficam os
/// parametros que o motor de calculo consome (franquia, excedente, fixo, datas,
/// reajuste, retencoes) sem necessidade de alterar o codigo-fonte por contrato.
model ProjectBillingConfig {
  id                    String              @id @default(cuid())
  projectId             String              @unique
  project               Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  periodicity           BillingPeriodicity  @default(MONTHLY)
  roundingRule          BillingRoundingRule @default(NONE)
  fixedAmount           Decimal?            @db.Decimal(12, 2)
  includedHours         Decimal?            @db.Decimal(10, 2)
  overageRate           Decimal?            @db.Decimal(12, 2)
  overageTreatment      OverageTreatment    @default(BILL_EXTRA)
  perConsultantAmount   Decimal?            @db.Decimal(12, 2)
  reimbursableExpenses  Boolean             @default(false)
  reimbursableMarkupPct Decimal?            @db.Decimal(5, 2)
  discountPct           Decimal?            @db.Decimal(5, 2)
  penaltyPct            Decimal?            @db.Decimal(5, 2)
  adjustmentIndex       AdjustmentIndex     @default(NONE)
  adjustmentPct         Decimal?            @db.Decimal(7, 4)
  withholdIss           Boolean             @default(false)
  withholdingPct        Decimal?            @db.Decimal(5, 2)
  closingDay            Int?
  dueDay                Int?
  requireApproval       Boolean             @default(true)
  // Hora extra (Onda 3 item 3.2): % aplicado sobre o valor das horas extras e
  // cobranca de excedente acima de um limite. `overtimeAppliesTo` define o(s)
  // vinculo(s) (CLT/PJ/ambos) em que a regra vale.
  overtimeAppliesTo     OvertimeAppliesTo   @default(NONE)
  overtimeBillingPct    Decimal?            @db.Decimal(5, 2)
  overtimeExcessHours   Decimal?            @db.Decimal(10, 2)
  overtimeExcessRate    Decimal?            @db.Decimal(12, 2)
  // Cobranca em ferias (Onda 3 item 3.5). E-mail e opcional via NotificationRule.
  billDuringVacation    Boolean             @default(true)
  parameters            Json?
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

model Allocation {
  id                     String                         @id @default(cuid())
  consultantId           String
  consultant             Consultant                     @relation(fields: [consultantId], references: [id])
  projectId              String
  project                Project                        @relation(fields: [projectId], references: [id])
  role                   String
  allocationPercent      Int
  startDate              DateTime
  endDate                DateTime?
  status                 AllocationStatus               @default(PLANNED)
  timeEntries            TimeEntry[]
  expenses               Expense[]
  timesheetDefault       TimesheetDefault?
  saleRates              ProjectSaleRate[]
  costRates              ConsultantAllocationCostRate[]
  consultantPaymentLines ConsultantPaymentLine[]
  allocationSkills       AllocationSkill[]
  adHocPayments          ConsultantAdHocPayment[]
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt

  @@index([consultantId])
  @@index([projectId])
}

model ProjectSaleRate {
  id           String      @id @default(cuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  consultantId String?
  consultant   Consultant? @relation(fields: [consultantId], references: [id], onDelete: SetNull)
  allocationId String?
  allocation   Allocation? @relation(fields: [allocationId], references: [id], onDelete: SetNull)
  startsAt     DateTime
  endsAt       DateTime?
  hourlyRate   Decimal     @db.Decimal(12, 2)
  currency     String      @default("BRL")
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([projectId, startsAt])
  @@index([consultantId])
  @@index([allocationId])
}

model ConsultantAllocationCostRate {
  id           String     @id @default(cuid())
  consultantId String
  consultant   Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  allocationId String
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Restrict)
  startsAt     DateTime
  endsAt       DateTime?
  hourlyCost   Decimal    @db.Decimal(12, 2)
  currency     String     @default("BRL")
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([consultantId, startsAt])
  @@index([allocationId, startsAt])
}

/// Consultant-maintained weekly default for an active allocation. It powers the
/// "Aplicar padrao da semana" flow without creating automatic hours silently:
/// the consultant explicitly previews/applies the pattern for the selected
/// week. `weekdays` stores ISO weekday numbers (1=Mon ... 7=Sun).
model TimesheetDefault {
  id           String     @id @default(cuid())
  allocationId String     @unique
  allocation   Allocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  activityType String     @default("WORKDAY")
  hoursPerDay  Decimal    @db.Decimal(5, 2)
  weekdays     Int[]      @default([1, 2, 3, 4, 5])
  billable     Boolean    @default(true)
  description  String?
  // Padrao de horario (formato "HH:mm"). Quando preenchido, alimenta o calculo de
  // horas no relogio de ponto e a comparacao com o "padrao definido" na aprovacao
  // automatica. breakStart/breakEnd nulos = sem pausa.
  startTime    String?
  breakStart   String?
  breakEnd     String?
  endTime      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model TimesheetPeriod {
  id           String                @id @default(cuid())
  consultantId String
  consultant   Consultant            @relation(fields: [consultantId], references: [id])
  startDate    DateTime
  endDate      DateTime
  status       TimesheetPeriodStatus @default(DRAFT)
  submittedAt  DateTime?
  entries      TimeEntry[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([consultantId, startDate, endDate])
}

model TimeEntry {
  id                     String                  @id @default(cuid())
  periodId               String
  period                 TimesheetPeriod         @relation(fields: [periodId], references: [id])
  consultantId           String
  consultant             Consultant              @relation(fields: [consultantId], references: [id])
  projectId              String
  project                Project                 @relation(fields: [projectId], references: [id])
  allocationId           String?
  allocation             Allocation?             @relation(fields: [allocationId], references: [id])
  /// Onda D (fluxo de ausencia): vinculo soft ao ConsultantTimeOff que originou
  /// este lancamento (materializado na aprovacao). SetNull: o lancamento
  /// sobrevive se a ausencia for removida.
  timeOffId              String?
  timeOff                ConsultantTimeOff?      @relation(fields: [timeOffId], references: [id], onDelete: SetNull)
  date                   DateTime
  // `hours` e derivado e persistido a partir dos horarios de ponto
  // (Saida - Inicio - pausa). Mantido como Decimal porque revenue/payment leem
  // diretamente entry.hours. Linhas legadas podem ter horarios nulos.
  hours                  Decimal                 @db.Decimal(5, 2)
  /// Fator de remuneracao do lancamento (melhoria #2: Sobreaviso vira
  /// Atividade). O consultor e sempre pago pelo equivalente
  /// `hours x multiplier`. Atividades normais usam 1.00 (effectiveHours ==
  /// hours); ON_CALL usa um fator fracionario (ex.: 0.33). O faturamento
  /// respeita a flag `billable`, nao o multiplier. Fonte unica de calculo:
  /// timeEntryEffectiveHours em @/lib/timesheet/effective-hours.
  multiplier             Decimal                 @default(1.00) @db.Decimal(5, 2)
  startTime              String?
  breakStart             String?
  breakEnd               String?
  endTime                String?
  activityType           String
  description            String?
  billable               Boolean                 @default(true)
  status                 TimeEntryStatus         @default(DRAFT)
  submittedAt            DateTime?
  /// Anexo opcional do lancamento (ex.: "ok do responsavel" no sobreaviso). 1:1
  /// generico, valido para qualquer activityType. Sucede OnCallAttachment.
  attachment             TimeEntryAttachment?
  revenueClosingLines    RevenueClosingLine[]
  consultantPaymentLines ConsultantPaymentLine[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([periodId])
  @@index([consultantId])
  @@index([projectId])
  @@index([allocationId])
  @@index([timeOffId])
  @@index([consultantId, date, status])
  @@index([status, submittedAt])
  // Global admin/consolidated report: month range across all consultants and
  // projects, without fixing consultantId/projectId. The other indexes lead
  // with consultantId/projectId/status, so a pure date-range filter would seq
  // scan without this single-column index.
  @@index([date])
}

/// Anexo generico de um lancamento de horas (1:1). Vale para qualquer
/// activityType; nasceu para carregar o "ok do responsavel" do sobreaviso
/// (melhoria #2), substituindo OnCallAttachment. Mesmo padrao de
/// ConsultantDocument/ExpenseAttachment: o arquivo vive em object storage
/// (bucket privado + chave), a URL e sempre assinada. onDelete Cascade: o
/// anexo segue o ciclo de vida do lancamento.
model TimeEntryAttachment {
  id               String    @id @default(cuid())
  timeEntryId      String    @unique
  timeEntry        TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)
  fileName         String
  contentType      String
  size             Int
  storageBucket    String
  storageKey       String
  uploadedByUserId String?
  createdAt        DateTime  @default(now())
}

model Approval {
  id             String               @id @default(cuid())
  entityType     ApprovableEntityType
  entityId       String
  approverUserId String?
  approver       User?                @relation("ApprovalApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  status         ApprovalStatus
  comment        String?
  isAutomatic    Boolean              @default(false)
  ruleKey        String?
  createdAt      DateTime             @default(now())

  @@index([entityType, entityId])
  @@index([approverUserId])
}

model Skill {
  id                 String                  @id @default(cuid())
  name               String
  category           String?
  /// Natureza da competencia. Default TECHNICAL para backfill seguro das linhas
  /// existentes (catalogo atual e majoritariamente tecnico); editavel no admin.
  type               SkillType               @default(TECHNICAL)
  status             SkillStatus             @default(ACTIVE)
  consultants        ConsultantSkill[]
  suggestions        SkillSuggestion[]
  allocations        AllocationSkill[]
  competencyItems    CompetencyProfileItem[]
  evaluationAnswers  EvaluationAnswer[]
  developmentActions DevelopmentAction[]
  courses            Course[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@unique([name, category])
}

/// Skill tag attached to a specific project Allocation. It is intentionally
/// isolated from ConsultantSkill: this records which catalog skill the
/// consultant is using ON THIS PROJECT, without touching the consultant's own
/// validated skill profile. Deleting the allocation removes its skill tags
/// (Cascade); catalog skills are protected (Restrict) so a referenced skill
/// cannot be deleted while still tagged on an allocation.
model AllocationSkill {
  id           String      @id @default(cuid())
  allocationId String
  allocation   Allocation  @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  skillId      String
  skill        Skill       @relation(fields: [skillId], references: [id], onDelete: Restrict)
  level        SkillLevel?
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([allocationId, skillId])
  @@index([allocationId])
  @@index([skillId])
}

model ConsultantSkill {
  id               String                   @id @default(cuid())
  consultantId     String
  consultant       Consultant               @relation(fields: [consultantId], references: [id])
  skillId          String
  skill            Skill                    @relation(fields: [skillId], references: [id])
  level            SkillLevel
  yearsExperience  Decimal?                 @db.Decimal(4, 1)
  lastUsedAt       DateTime?
  validationStatus ValidationStatus         @default(PENDING)
  evidences        SkillEvidence[]
  history          ConsultantSkillHistory[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([consultantId, skillId])
  @@index([skillId])
}

/// Human-reviewed skill suggestion generated from weekly activity evidence.
/// The assistant proposes; the consultant decides. Existing catalog skills can
/// be accepted into ConsultantSkill as PENDING validation. Unknown skills stay
/// as suggestions and do not become ACTIVE catalog rows automatically.
model SkillSuggestion {
  id                String                @id @default(cuid())
  consultantId      String
  consultant        Consultant            @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  weekStart         DateTime
  weekEnd           DateTime
  skillId           String?
  skill             Skill?                @relation(fields: [skillId], references: [id], onDelete: SetNull)
  suggestedName     String
  suggestedCategory String?
  suggestedLevel    SkillLevel            @default(INTERMEDIATE)
  evidenceSummary   String?
  sourceEntryIds    String[]              @default([])
  status            SkillSuggestionStatus @default(PENDING)
  decidedAt         DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([consultantId, weekStart, suggestedName])
  @@index([consultantId, weekStart])
  @@index([skillId])
  @@index([status])
}

/// Perfil de competencias esperado (nivel requerido) por senioridade, cargo ou
/// area. Onda 0 (Talentos): base do gap analysis (requerido x atual). O alvo do
/// perfil e identificado por scope + referenceKey (chave logica livre, sem FK a
/// uma tabela de cargos ainda inexistente). Soft delete via status reusando o
/// enum SkillStatus (ACTIVE/INACTIVE), padrao das entidades operacionais.
model CompetencyProfile {
  id           String                  @id @default(cuid())
  name         String
  scope        CompetencyScope
  referenceKey String
  status       SkillStatus             @default(ACTIVE)
  items        CompetencyProfileItem[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([scope, referenceKey])
  @@index([status])
}

/// Item de um perfil de competencias: o nivel requerido (SkillLevel) de uma
/// skill dentro do perfil. Cascade no perfil (itens morrem com o perfil); a skill
/// e protegida (Restrict) para nao apagar um item de catalogo ainda referenciado.
/// Unico por (profileId, skillId): uma skill aparece no maximo uma vez por perfil.
model CompetencyProfileItem {
  id            String            @id @default(cuid())
  profileId     String
  profile       CompetencyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skillId       String
  skill         Skill             @relation(fields: [skillId], references: [id], onDelete: Restrict)
  requiredLevel SkillLevel
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([profileId, skillId])
  @@index([profileId])
  @@index([skillId])
}

/// Evidencia que sustenta o nivel atual de uma competencia do consultor. Cascade
/// no ConsultantSkill (a evidencia perde sentido sem a skill do consultor).
/// sourceId aponta para o registro de origem (ex.: feedbackId, certificateId)
/// quando aplicavel; e mantido como String solta para nao acoplar a entidades de
/// ondas futuras (avaliacao, feedback) que ainda nao existem.
model SkillEvidence {
  id                String              @id @default(cuid())
  consultantSkillId String
  consultantSkill   ConsultantSkill     @relation(fields: [consultantSkillId], references: [id], onDelete: Cascade)
  sourceType        SkillEvidenceSource
  sourceId          String?
  note              String?
  createdAt         DateTime            @default(now())

  // Idempotencia da evidencia de origem (ex.: conclusao de curso -> sourceId =
  // enrollmentId). sourceId e nullable: no Postgres um unique com coluna NULL
  // permite multiplos NULL (cada NULL e distinto), entao a trava so atua quando
  // sourceId esta preenchido — exatamente o caso da evidencia de curso. Evita
  // evidencia duplicada sob corrida na conclusao da matricula.
  @@unique([consultantSkillId, sourceId])
  @@index([consultantSkillId])
}

/// Historico de evolucao de nivel de uma competencia do consultor (append-only).
/// Uma linha por mudanca de nivel, preservando a trilha de auditoria leve da skill.
/// Cascade no ConsultantSkill; changedByUser opcional (SetNull) para manter o
/// historico mesmo se o usuario que alterou for removido.
model ConsultantSkillHistory {
  id                String          @id @default(cuid())
  consultantSkillId String
  consultantSkill   ConsultantSkill @relation(fields: [consultantSkillId], references: [id], onDelete: Cascade)
  level             SkillLevel
  changedByUserId   String?
  changedByUser     User?           @relation("SkillHistoryChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)
  reason            String?
  createdAt         DateTime        @default(now())

  @@index([consultantSkillId])
}

/// Feedback continuo sobre um consultor (EP15), ancorado opcionalmente a um
/// projeto/cliente reais. Forma o historico que alimenta avaliacao e score.
/// Cascade no consultor (o feedback nao faz sentido sem o avaliado); autor e
/// SetNull para preservar o registro se o usuario for removido. visibility
/// (PRIVATE/SHARED) e a regra LGPD aplicada no servidor: PRIVATE so e visto por
/// autor + PEOPLE + gestor responsavel. Os campos de voz/IA (audioStorageKey,
/// transcription, transcriptionStatus) sao apoio para o incremento atras de
/// feature flag; sem logica no banco.
model Feedback {
  id                  String              @id @default(cuid())
  subjectConsultantId String
  subjectConsultant   Consultant          @relation("FeedbackSubject", fields: [subjectConsultantId], references: [id], onDelete: Cascade)
  authorUserId        String?
  author              User?               @relation("FeedbackAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  type                FeedbackType
  source              FeedbackSource
  visibility          FeedbackVisibility  @default(PRIVATE)
  body                String
  relatedProjectId    String?
  relatedProject      Project?            @relation(fields: [relatedProjectId], references: [id], onDelete: SetNull)
  relatedClientId     String?
  relatedClient       Client?             @relation(fields: [relatedClientId], references: [id], onDelete: SetNull)
  audioStorageKey     String?
  transcription       String?
  transcriptionStatus TranscriptionStatus @default(NONE)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([subjectConsultantId])
  @@index([subjectConsultantId, createdAt])
}

/// Ciclo de avaliacao 90/180/360 (EP16). createdBy e SetNull para preservar o
/// ciclo se o criador for removido. As Evaluation morrem com o ciclo (Cascade).
model EvaluationCycle {
  id               String                @id @default(cuid())
  name             String
  type             EvaluationType
  periodStart      DateTime
  periodEnd        DateTime
  status           EvaluationCycleStatus @default(DRAFT)
  createdByUserId  String?
  createdBy        User?                 @relation("EvaluationCycleCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  evaluations      Evaluation[]
  developmentPlans DevelopmentPlan[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

/// A avaliacao de um consultor dentro de um ciclo. Unica por (ciclo, consultor).
/// Cascade no ciclo e no consultor (a avaliacao nao existe sem ambos).
model Evaluation {
  id                  String               @id @default(cuid())
  cycleId             String
  cycle               EvaluationCycle      @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  subjectConsultantId String
  subjectConsultant   Consultant           @relation(fields: [subjectConsultantId], references: [id], onDelete: Cascade)
  status              EvaluationStatus     @default(PENDING)
  responses           EvaluationResponse[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([cycleId, subjectConsultantId])
}

/// Uma resposta de avaliador dentro de uma avaliacao. raterUserId e SetNull e
/// opcional (avaliador-cliente sem usuario, ou usuario removido preserva a
/// resposta). relationship distingue SELF/MANAGER/PEER/CLIENT/SUBORDINATE.
model EvaluationResponse {
  id           String                 @id @default(cuid())
  evaluationId String
  evaluation   Evaluation             @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  raterUserId  String?
  rater        User?                  @relation("EvaluationResponseRater", fields: [raterUserId], references: [id], onDelete: SetNull)
  relationship EvaluationRelationship
  status       EvaluationStatus       @default(PENDING)
  submittedAt  DateTime?
  answers      EvaluationAnswer[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([evaluationId, relationship])
  @@index([evaluationId])
}

/// Nota por competencia dentro de uma resposta. Cascade na resposta; a skill e
/// protegida (Restrict) por ser catalogo referenciado. score 1-5 validado na
/// app. Unico por (resposta, skill): uma nota por competencia por avaliador.
model EvaluationAnswer {
  id         String             @id @default(cuid())
  responseId String
  response   EvaluationResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  skillId    String
  skill      Skill              @relation(fields: [skillId], references: [id], onDelete: Restrict)
  score      Int
  comment    String?
  createdAt  DateTime           @default(now())

  @@unique([responseId, skillId])
  @@index([responseId])
}

/// Plano de Desenvolvimento Individual (EP17). Cascade no consultor; cycleId
/// opcional (SetNull) liga o PDI ao ciclo de avaliacao que o originou; owner e
/// SetNull. Soft delete operacional via status (CANCELLED).
model DevelopmentPlan {
  id           String                @id @default(cuid())
  consultantId String
  consultant   Consultant            @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  cycleId      String?
  cycle        EvaluationCycle?      @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  ownerUserId  String?
  owner        User?                 @relation("DevelopmentPlanOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  status       DevelopmentPlanStatus @default(ACTIVE)
  periodStart  DateTime
  periodEnd    DateTime
  actions      DevelopmentAction[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([consultantId])
}

/// Acao concreta de um PDI. Cascade no plano; targetSkill opcional (SetNull) e a
/// skill alvo da acao, derivada do gap. evidenceNote registra a comprovacao da
/// conclusao (futuro: vinculo com Certificate/Universidade/Expense).
model DevelopmentAction {
  id            String                  @id @default(cuid())
  planId        String
  plan          DevelopmentPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  type          DevelopmentActionType
  targetSkillId String?
  targetSkill   Skill?                  @relation(fields: [targetSkillId], references: [id], onDelete: SetNull)
  description   String
  dueAt         DateTime?
  status        DevelopmentActionStatus @default(PLANNED)
  evidenceNote  String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([planId])
}

/// Ausencia agendada com datas concretas de gozo (ferias/licenca/outros).
/// Complementa ConsultantVacation (que e o ledger de periodo aquisitivo, NAO
/// alterado) e e a fonte real do heatmap de disponibilidade (EP11): substitui o
/// proxy da Onda 0. Cascade no consultor. status permite soft cancel.
model ConsultantTimeOff {
  id           String        @id @default(cuid())
  consultantId String
  consultant   Consultant    @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  kind         TimeOffKind
  startDate    DateTime
  endDate      DateTime
  status       TimeOffStatus @default(PLANNED)
  note         String?
  /// Onda D (fluxo de ausencia). Ausencia REMUNERADA (true, default) vs nao
  /// remunerada: orienta calculo de custo/pagamento na aplicacao.
  paid         Boolean       @default(true)
  /// Trilha do pedido/decisao. Referencias soltas ao User (padrao do projeto:
  /// sem FK, para nao acoplar auditoria ao ciclo de vida de User).
  requestedByUserId String?
  requestedAt       DateTime?
  approvedByUserId  String?
  decidedAt         DateTime?
  decisionComment   String?
  /// Vinculo opcional com o saldo de ferias (SetNull: a ausencia sobrevive a
  /// remocao do registro de ferias). Preenchido quando kind = ferias.
  vacationId       String?
  vacation         ConsultantVacation? @relation(fields: [vacationId], references: [id], onDelete: SetNull)
  /// Dias uteis calculados (exclui fins de semana e feriados); base para gerar
  /// os TimeEntry materializados na aprovacao.
  workingDays      Int?
  /// TimeEntry materializados a partir desta ausencia (FK soft em TimeEntry,
  /// SetNull: os lancamentos sobrevivem se a ausencia for removida).
  generatedEntries TimeEntry[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([consultantId, startDate])
  @@index([vacationId])
}

/// Pesquisa interna de clima/NPS (EP 7.1). createdBy e SetNull para preservar a
/// pesquisa se o criador for removido. anonymous = true por padrao: nesse caso a
/// aplicacao NAO deve correlacionar resposta e identidade (ver SurveyResponse).
/// Soft close via status; nao ha exclusao destrutiva de pesquisa com respostas.
model Survey {
  id              String             @id @default(cuid())
  title           String
  description     String?
  type            SurveyType
  anonymous       Boolean            @default(true)
  status          SurveyStatus       @default(DRAFT)
  periodStart     DateTime?
  periodEnd       DateTime?
  createdByUserId String?
  createdBy       User?              @relation("SurveyCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  questions       SurveyQuestion[]
  invitations     SurveyInvitation[]
  responses       SurveyResponse[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

/// Questao de uma pesquisa. Cascade na pesquisa (a questao nao existe sem ela).
/// options (Json) guarda as alternativas quando type = CHOICE; order define a
/// ordem de exibicao.
model SurveyQuestion {
  id        String             @id @default(cuid())
  surveyId  String
  survey    Survey             @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  text      String
  type      SurveyQuestionType
  options   Json?
  order     Int                @default(0)
  answers   SurveyAnswer[]
  createdAt DateTime           @default(now())

  @@index([surveyId])
}

/// Convite de resposta a uma pesquisa. E o UNICO mecanismo de controle de "quem
/// respondeu", deliberadamente DESACOPLADO do conteudo das respostas: em pesquisa
/// anonima a aplicacao usa este registro apenas para saber se o consultor ja
/// respondeu (status) e nao para reconstruir quem disse o que. tokenHash guarda
/// somente o digest do token de acesso entregue ao convidado; nunca o token cru.
/// Cascade no survey e no consultor. Unico por (surveyId, consultantId).
model SurveyInvitation {
  id           String                 @id @default(cuid())
  surveyId     String
  survey       Survey                 @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  consultantId String
  consultant   Consultant             @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  tokenHash    String                 @unique
  status       SurveyInvitationStatus @default(PENDING)
  respondedAt  DateTime?
  responses    SurveyResponse[]
  createdAt    DateTime               @default(now())

  @@unique([surveyId, consultantId])
  @@index([surveyId])
}

/// Resposta submetida a uma pesquisa. ANONIMATO E REGRA DE MODELAGEM: NAO ha
/// consultantId aqui. O unico vinculo possivel e via invitationId, mantido como
/// SetNull/opcional para que em pesquisa anonima a aplicacao possa nem gravar o
/// vinculo (ou desliga-lo), evitando correlacionar resposta x identidade. Cascade
/// no survey. Quem implementa: em pesquisa anonima, NAO use invitationId para
/// reidentificar o respondente; use SurveyInvitation.status apenas para "ja
/// respondeu". Em pesquisa nao anonima, o vinculo via invitation e permitido.
model SurveyResponse {
  id           String            @id @default(cuid())
  surveyId     String
  survey       Survey            @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  invitationId String?
  invitation   SurveyInvitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  submittedAt  DateTime
  answers      SurveyAnswer[]
  createdAt    DateTime          @default(now())

  @@index([surveyId])
}

/// Resposta a uma questao especifica. Cascade na resposta; a questao e protegida
/// (Restrict) por ser parte do "catalogo" da pesquisa ja respondida. Um dos
/// campos de valor e usado conforme o tipo da questao: scoreValue (SCALE/NPS),
/// choiceValue (CHOICE), textValue (TEXT). Validacao do preenchimento no servidor.
model SurveyAnswer {
  id          String         @id @default(cuid())
  responseId  String
  response    SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId  String
  question    SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)
  scoreValue  Int?
  choiceValue String?
  textValue   String?
  createdAt   DateTime       @default(now())

  @@index([responseId])
}

/// Objetivo / OKR (EP 7.2). O alvo logico vem de scope + referenceKey (chave
/// livre, ex.: area 'DATA') e/ou das FKs opcionais consultantId/projectId. owner,
/// consultant e project sao SetNull para preservar o objetivo se o ator/alvo for
/// removido. Soft delete operacional via status (CANCELLED).
model Objective {
  id           String          @id @default(cuid())
  scope        ObjectiveScope
  referenceKey String?
  title        String
  description  String?
  periodStart  DateTime
  periodEnd    DateTime
  status       ObjectiveStatus @default(DRAFT)
  ownerUserId  String?
  owner        User?           @relation("ObjectiveOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  consultantId String?
  consultant   Consultant?     @relation(fields: [consultantId], references: [id], onDelete: SetNull)
  projectId    String?
  project      Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  keyResults   KeyResult[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([scope, referenceKey])
  @@index([consultantId])
  @@index([projectId])
}

/// Resultado-chave de um objetivo (KR). Cascade no objetivo (o KR nao existe sem
/// ele). startValue/targetValue/currentValue em Decimal(14,2) cobrem metricas
/// monetarias e numericas; o progresso e DERIVADO no servidor a partir desses
/// valores conforme metricType (nao ha coluna de progresso). autoSource e uma
/// chave de fonte operacional para auto-atualizacao futura (ex.: 'margin',
/// 'hours'); apenas marcacao, sem logica no banco.
model KeyResult {
  id           String          @id @default(cuid())
  objectiveId  String
  objective    Objective       @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  title        String
  metricType   KeyResultMetric @default(NUMBER)
  startValue   Decimal         @default(0) @db.Decimal(14, 2)
  targetValue  Decimal         @db.Decimal(14, 2)
  currentValue Decimal         @default(0) @db.Decimal(14, 2)
  unit         String?
  autoSource   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([objectiveId])
}

/// Trilha de capacitacao da Universidade Jump (EP 7.3). Agrupa cursos. Soft
/// delete via status (INACTIVE), padrao de catalogo.
model LearningTrack {
  id          String         @id @default(cuid())
  title       String
  description String?
  category    String?
  status      LearningStatus @default(ACTIVE)
  courses     Course[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

/// Curso da Universidade Jump. track opcional (SetNull) agrupa em trilha; skill
/// opcional (SetNull) liga o curso a uma competencia do catalogo (conclusao pode
/// alimentar ConsultantSkill/evidencia no futuro). Soft delete via status.
model Course {
  id          String         @id @default(cuid())
  trackId     String?
  track       LearningTrack? @relation(fields: [trackId], references: [id], onDelete: SetNull)
  title       String
  provider    String?
  hours       Decimal?       @db.Decimal(6, 2)
  externalUrl String?
  skillId     String?
  skill       Skill?         @relation(fields: [skillId], references: [id], onDelete: SetNull)
  status      LearningStatus @default(ACTIVE)
  enrollments Enrollment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([trackId])
  @@index([skillId])
}

/// Matricula de um consultor em um curso. Cascade no consultor e no curso (a
/// matricula nao existe sem ambos). Unica por (consultantId, courseId). progressPct
/// e hoursCompleted alimentam o painel; pontos/ranking de gamificacao sao DERIVADOS
/// das matriculas COMPLETED (sem tabela de pontos). Soft cancel via status.
model Enrollment {
  id             String           @id @default(cuid())
  consultantId   String
  consultant     Consultant       @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  courseId       String
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status         EnrollmentStatus @default(ENROLLED)
  progressPct    Int              @default(0)
  hoursCompleted Decimal          @default(0) @db.Decimal(6, 2)
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([consultantId, courseId])
  @@index([consultantId])
  @@index([courseId])
}

model Certificate {
  id            String           @id @default(cuid())
  consultantId  String
  consultant    Consultant       @relation(fields: [consultantId], references: [id])
  name          String
  issuer        String
  issuedAt      DateTime
  expiresAt     DateTime?
  credentialId  String?
  credentialUrl String?
  fileUrl       String?
  status        ValidationStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([consultantId])
}

model MonthlyClosing {
  id             String               @id @default(cuid())
  clientId       String
  client         Client               @relation(fields: [clientId], references: [id])
  projectId      String
  project        Project              @relation(fields: [projectId], references: [id])
  month          Int
  year           Int
  status         MonthlyClosingStatus @default(OPEN)
  totalHours     Decimal              @db.Decimal(10, 2)
  totalAmount    Decimal              @db.Decimal(12, 2)
  closedByUserId String?
  closedAt       DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([projectId, month, year])
  @@index([clientId])
}

/// Fechamento operacional de um projeto num mes, para o Departamento Pessoal.
/// Independente do RevenueClosing (faturamento): aqui o gestor sinaliza que toda
/// a equipe alocada lancou e teve as horas APROVADAS no mes, disparando a
/// notificacao ao DP. `consultantsSnapshot` congela a lista de consultores
/// (nome/horas) no instante do fechamento, para o e-mail refletir o estado real
/// mesmo que a alocacao mude depois. closedBy/reopenedBy guardam apenas o id
/// (sem relacao, como MonthlyClosing); o nome e resolvido na leitura.
model OperationClosing {
  id                  String                 @id @default(cuid())
  projectId           String
  project             Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  month               Int
  year                Int
  status              OperationClosingStatus @default(OPEN)
  closedByUserId      String?
  closedAt            DateTime?
  reopenedByUserId    String?
  reopenedAt          DateTime?
  notifiedAt          DateTime?
  consultantsSnapshot Json?
  notes               String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([projectId, month, year])
  @@index([status, year, month])
}

model RevenueClosing {
  id               String               @id @default(cuid())
  clientId         String
  client           Client               @relation(fields: [clientId], references: [id])
  projectId        String?
  project          Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  month            Int
  year             Int
  status           RevenueClosingStatus @default(OPEN)
  totalHours       Decimal              @default(0) @db.Decimal(10, 2)
  grossAmount      Decimal              @default(0) @db.Decimal(12, 2)
  adjustmentAmount Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal              @default(0) @db.Decimal(12, 2)
  notes            String?
  closedByUserId   String?
  closedBy         User?                @relation("RevenueClosingCloser", fields: [closedByUserId], references: [id], onDelete: SetNull)
  closedAt         DateTime?
  lines            RevenueClosingLine[]
  fiscalDocuments  FiscalDocument[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([clientId, projectId, month, year])
  @@index([clientId])
  @@index([projectId])
  @@index([status])
}

model RevenueClosingLine {
  id               String         @id @default(cuid())
  revenueClosingId String
  revenueClosing   RevenueClosing @relation(fields: [revenueClosingId], references: [id], onDelete: Cascade)
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id])
  timeEntryId      String?
  timeEntry        TimeEntry?     @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  description      String?
  hours            Decimal        @default(0) @db.Decimal(10, 2)
  unitRate         Decimal        @default(0) @db.Decimal(12, 2)
  amount           Decimal        @default(0) @db.Decimal(12, 2)
  createdAt        DateTime       @default(now())

  @@index([revenueClosingId])
  @@index([projectId])
  @@index([timeEntryId])
}

model FiscalDocument {
  id                String                  @id @default(cuid())
  kind              FiscalDocumentKind      @default(NFSE)
  status            FiscalDocumentStatus    @default(DRAFT)
  clientId          String
  client            Client                  @relation(fields: [clientId], references: [id])
  revenueClosingId  String?
  revenueClosing    RevenueClosing?         @relation(fields: [revenueClosingId], references: [id], onDelete: SetNull)
  provider          IntegrationProviderKind @default(SAO_PAULO_NFSE)
  invoiceNumber     String?
  protocol          String?
  xmlStorageBucket  String?
  xmlStorageKey     String?
  pdfStorageBucket  String?
  pdfStorageKey     String?
  errorMessage      String?
  validatedByUserId String?
  validatedBy       User?                   @relation("FiscalDocumentValidator", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  issuedAt          DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@unique([provider, invoiceNumber])
  @@index([clientId])
  @@index([revenueClosingId])
  @@index([status])
  @@index([invoiceNumber])
}

model ConsultantPaymentForecast {
  id                 String              @id @default(cuid())
  consultantId       String?
  consultant         Consultant?         @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  closingMonth       Int
  closingYear        Int
  responseDeadlineAt DateTime
  expectedPaymentAt  DateTime
  createdByUserId    String?
  createdBy          User?               @relation("PaymentForecastCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  payments           ConsultantPayment[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([consultantId])
  @@index([closingYear, closingMonth])
}

model ConsultantPayment {
  id                 String                     @id @default(cuid())
  consultantId       String
  consultant         Consultant                 @relation(fields: [consultantId], references: [id])
  forecastId         String?
  forecast           ConsultantPaymentForecast? @relation(fields: [forecastId], references: [id], onDelete: SetNull)
  month              Int
  year               Int
  contractType       ConsultantContractType
  status             ConsultantPaymentStatus    @default(OPEN)
  cltNetAmount       Decimal                    @default(0) @db.Decimal(12, 2)
  pjAmount           Decimal                    @default(0) @db.Decimal(12, 2)
  benefitAmount      Decimal                    @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal                    @default(0) @db.Decimal(12, 2)
  expectedPaymentAt  DateTime?
  confirmedPaidAt    DateTime?
  invoiceReceivedAt  DateTime?
  invoiceValidatedAt DateTime?
  approvedByUserId   String?
  approvedBy         User?                      @relation("ConsultantPaymentApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  approvedAt         DateTime?
  lines              ConsultantPaymentLine[]
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  @@unique([consultantId, month, year])
  @@index([forecastId])
  @@index([status])
  @@index([year, month])
}

model ConsultantPaymentLine {
  id                  String            @id @default(cuid())
  consultantPaymentId String
  consultantPayment   ConsultantPayment @relation(fields: [consultantPaymentId], references: [id], onDelete: Cascade)
  projectId           String?
  project             Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  allocationId        String?
  allocation          Allocation?       @relation(fields: [allocationId], references: [id], onDelete: SetNull)
  timeEntryId         String?
  timeEntry           TimeEntry?        @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  description         String
  hours               Decimal           @default(0) @db.Decimal(10, 2)
  unitRate            Decimal           @default(0) @db.Decimal(12, 2)
  amount              Decimal           @default(0) @db.Decimal(12, 2)
  createdAt           DateTime          @default(now())

  @@index([consultantPaymentId])
  @@index([projectId])
  @@index([allocationId])
  @@index([timeEntryId])
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  entityType  String
  entityId    String
  action      String
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

/// Regra de aprovacao automatica por PROJETO. Duas excecoes nao excludentes
/// (combinadas por OU): fim de semana e range de horas POR LANCAMENTO. O range
/// usa minutos (00:01 = 1, 23:59 = 1439); min/max nunca 0 e max >= min. Vale
/// para todos os consultores do projeto, EXCETO quando existem regras por
/// consultor (modo exclusivo: ver ConsultantAutoApprovalRule).
model ProjectAutoApprovalRule {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)
  /// Regra inativa e ignorada pelo motor (como se nao existisse), mas mantida
  /// para reativacao. Inativar a regra do projeto faz o motor cair no fallback.
  active            Boolean  @default(true)
  weekendEnabled    Boolean  @default(false)
  hoursRangeEnabled Boolean  @default(false)
  minMinutes        Int      @default(1)
  maxMinutes        Int      @default(1439)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Regra de aprovacao automatica por CONSULTOR dentro de um projeto. A
/// existencia de QUALQUER regra por consultor no projeto suspende a regra do
/// projeto (modo exclusivo): so os consultores com regra propria tem aprovacao
/// automatica; os demais ficam manuais. Mesma semantica de FDS/range.
model ConsultantAutoApprovalRule {
  id                String     @id @default(cuid())
  consultantId      String
  consultant        Consultant @relation(fields: [consultantId], references: [id], onDelete: Restrict)
  projectId         String
  project           Project    @relation(fields: [projectId], references: [id], onDelete: Restrict)
  /// Regra inativa e ignorada pelo motor (nao conta para o modo exclusivo);
  /// mantida para reativacao.
  active            Boolean    @default(true)
  weekendEnabled    Boolean    @default(false)
  hoursRangeEnabled Boolean    @default(false)
  minMinutes        Int        @default(1)
  maxMinutes        Int        @default(1439)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@unique([consultantId, projectId])
  @@index([projectId])
}

/// Singleton tunables for the automation engine. Always read/written via
/// upsert on id = "default".
model AutomationConfig {
  id                   String   @id @default("default")
  autoApprovalEnabled  Boolean  @default(true)
  requiredDailyMinutes Int      @default(480)
  approvalDelayMinutes Int      @default(5)
  reportRecipientEmail String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Delivery log for automated emails. The unique (type, referenceKey) is the
/// idempotency key: a given report period is sent at most once.
model AutomationEmailLog {
  id           String              @id @default(cuid())
  type         AutomationEmailType
  referenceKey String
  recipient    String
  status       EmailDeliveryStatus
  error        String?
  meta         Json?
  createdAt    DateTime            @default(now())

  @@unique([type, referenceKey])
  @@index([createdAt])
}

enum NotificationChannel {
  EMAIL
  TEAMS
}

/// Eventos operacionais que disparam notificacao. Estender conforme as ondas do
/// plano de melhorias (docs/plano-melhorias-financeiro-operacional.md).
enum NotificationEvent {
  HOURS_RELEASED // 1.1 liberacao de horas
  CLIENT_BILLING_SUMMARY // 1.2 apuracao ao cliente por consultor
  OVERTIME_ALERT // 2.5/3.3 alerta de hora extra (PJ/CLT)
  PROJECT_CREATED // 6.1 cadastro de novo projeto
  INVOICING_OVERDUE // 4.3/5.2 faturamento nao realizado
  COMMERCIAL_CONTRACT_MISSING // 6.2 contrato comercial ausente
  OPERATION_CLOSED // fechamento operacional do projeto para o DP
  FEED_POST_REPLIED // melhoria #5: alguem respondeu seu post no feed
  FEED_CONTENT_REACTED // melhoria #5: reacoes ao seu post/comentario (digest agregado)
  FEED_MENTIONED // melhoria #5: voce foi mencionado (@) num post/comentario
  HOLIDAY_UPCOMING // Onda A/2: feriado proximo (job agendado varre o calendario)
  MISSING_TIMESHEET_REPORT // relatorio semanal de ausencia de lancamento (CSV)
  ACCESS_INVITE // convite de acesso / novo link (destinatario = convidado)
  PRE_INVOICE_ISSUED // pre-fatura enviada ao contato do cliente
  NFSE_ISSUED // NFS-e emitida, e-mail ao contato do cliente
  PAYMENT_FORECAST // previsao de pagamento ao consultor
}

/// Nivel de agregacao em que a regra dispara.
enum NotificationScope {
  GLOBAL
  PROJECT
  ALLOCATION
}

/// Como o endereco do destinatario e resolvido em tempo de envio.
enum NotificationRecipientType {
  STATIC // address e um e-mail literal ou URL de webhook (ex.: varios e-mails p/ NF)
  ROLE // address e um RoleName; expande para usuarios com aquele papel
  PROJECT_MANAGER // resolve para o gestor do projeto (scope = PROJECT) — remetente/destino 1.4
  CLIENT_CONTACT // resolve para o contato de cobranca do cliente (1.2)
  EVENT_TARGET // destinatario inerente ao evento (convidado, consultor, lista do relatorio)
}

/// Regra de notificacao: para um evento + escopo, define canal, destinatarios e
/// se consolida multiplos fragmentos por destinatario (agrupamento por usuario).
model NotificationRule {
  id               String                  @id @default(cuid())
  event            NotificationEvent
  scope            NotificationScope       @default(GLOBAL)
  /// projectId/allocationId quando scope != GLOBAL; null no escopo global.
  scopeId          String?
  channel          NotificationChannel     @default(EMAIL)
  /// Consolida varios fragmentos do mesmo destinatario num unico envio.
  groupByRecipient Boolean                 @default(true)
  active           Boolean                 @default(true)
  recipients       NotificationRecipient[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([event, active])
  @@index([scope, scopeId])
}

/// Destinatario de uma regra. Varios por regra (ex.: lista de e-mails para
/// aprovacao de NF). `address` guarda e-mail/URL (STATIC), RoleName (ROLE) ou
/// fica vazio quando o tipo resolve dinamicamente (PROJECT_MANAGER/CLIENT_CONTACT).
model NotificationRecipient {
  id        String                    @id @default(cuid())
  ruleId    String
  rule      NotificationRule          @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  type      NotificationRecipientType @default(STATIC)
  channel   NotificationChannel       @default(EMAIL)
  /// E-mail/URL do webhook (STATIC) ou RoleName (ROLE). URL e tratada como segredo.
  address   String?
  name      String?
  createdAt DateTime                  @default(now())

  @@index([ruleId])
}

model IntegrationEvent {
  id             String                  @id @default(cuid())
  provider       IntegrationProviderKind
  operation      String
  status         IntegrationEventStatus  @default(PENDING)
  entityType     String?
  entityId       String?
  idempotencyKey String?
  requestMeta    Json?
  responseMeta   Json?
  error          String?
  attemptedAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@unique([provider, idempotencyKey])
  @@index([provider, status])
  @@index([entityType, entityId])
  @@index([createdAt])
}

/// Abrangencia de um feriado no calendario.
enum HolidayScope {
  NATIONAL
  STATE
  CITY
}

/// Calendario de feriados. Base de dados para notificacao de feriado e aviso ao
/// apontar horas em feriado (Onda A do plano de melhorias). `date` e armazenada
/// como data pura (@db.Date). Para feriados nao-nacionais, `region` guarda a UF
/// (STATE) ou o municipio (CITY); nacionais tem region null.
/// Feriado do calendario operacional. Aplicabilidade por projeto (Onda A-ext):
/// sem nenhum vinculo em `projects` => feriado GLOBAL (vale para todos os
/// projetos, caso dos nacionais); com >=1 vinculo => vale SOMENTE para os
/// projetos vinculados (folga de cliente, feriado regional). A de-duplicacao
/// (mesma data/escopo/regiao) e responsabilidade da Server Action de CRUD, nao
/// do banco: o antigo `@@unique([date, scope, region])` era uma falsa garantia
/// porque no Postgres NULLs sao distintos entre si (feriados nacionais tem
/// region NULL, entao duplicatas passavam pelo indice unico). Mantemos apenas
/// indices de consulta; a tela lista os feriados e a action valida a colisao.
model Holiday {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date
  name      String
  scope     HolidayScope     @default(NATIONAL)
  region    String?
  year      Int
  projects  HolidayProject[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([date, scope])
  @@index([year])
}

/// Tabela de juncao Holiday<->Project (N:N). A presenca de linhas restringe o
/// feriado aos projetos vinculados; a ausencia de linhas o mantem GLOBAL.
/// `onDelete: Cascade` no lado Holiday remove os vinculos junto com o feriado;
/// o lado Project usa a acao padrao (Restrict), coerente com as demais FKs para
/// Project no schema (Expense, TimeEntry, Allocation), protegendo contra remocao
/// acidental de projeto com vinculos.
model HolidayProject {
  holidayId String
  holiday   Holiday  @relation(fields: [holidayId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())

  @@id([holidayId, projectId])
  @@index([projectId])
}

/// Consultant expense tied to a project (and the active allocation that
/// authorized it). `date` is stored as UTC midnight (date-only semantics,
/// same convention as TimeEntry.date). Status transitions, RBAC and the
/// "active allocation covering the expense date" rule are enforced in
/// Server Actions; sensitive transitions emit AuditEvent + Approval rows.
model Expense {
  id            String             @id @default(cuid())
  consultantId  String
  consultant    Consultant         @relation(fields: [consultantId], references: [id])
  projectId     String
  project       Project            @relation(fields: [projectId], references: [id])
  allocationId  String?
  allocation    Allocation?        @relation(fields: [allocationId], references: [id])
  date          DateTime
  amount        Decimal            @db.Decimal(12, 2)
  description   String
  invoiceNumber String?
  /// Categoria do lancamento. Nullable para back-compat com Expenses
  /// pre-existentes; novos lancamentos exigem categoria via Zod no servidor.
  category      ExpenseCategory?
  /// Chave de agrupamento por NF/lote (cuid gerado no formulario). Permite
  /// "uma descricao para varias despesas" sem entidade pai: o form cria N
  /// linhas Expense numa transacao compartilhando description, invoiceNumber e
  /// groupId. A UI agrupa por groupId; invoiceNumber permanece dado fiscal.
  groupId       String?
  status        ExpenseStatus      @default(DRAFT)
  submittedAt   DateTime?
  attachment    ExpenseAttachment?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([consultantId])
  @@index([projectId])
  @@index([allocationId])
  @@index([status, submittedAt])
  @@index([consultantId, date])
  @@index([consultantId, groupId])
  // Global finance/consolidated report: month range across all consultants and
  // projects (mirrors TimeEntry.date). Leading columns of the other indexes are
  // consultantId/projectId/status, so a pure date-range filter needs this.
  @@index([date])
}

/// Receipt metadata for an expense (file itself lives in object storage,
/// bucket `expense-receipts`). Separate model (1:1 today) so evolving to
/// multiple attachments per expense is a relation change, not a rewrite.
/// Cascade delete: removing a DRAFT expense also removes the metadata row.
model ExpenseAttachment {
  id               String   @id @default(cuid())
  expenseId        String   @unique
  expense          Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  fileName         String
  contentType      String
  size             Int
  storageBucket    String
  storageKey       String
  uploadedByUserId String?
  uploadedBy       User?    @relation("ExpenseAttachmentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([uploadedByUserId])
}

/// Post do feed social interno (Melhoria #5, fatia 1). Autoria por User com
/// onDelete SetNull (preserva o post se o autor sair). Soft delete por `status`.
/// Moderacao (ADMIN/PEOPLE) usa removedByUserId/removedAt/removalReason; edicao
/// do proprio autor marca editedAt. `pinned` e regra de app (max 3 por
/// moderadores), nao schema. No v1 so visibility = PUBLIC_INTERNAL; AREA fica
/// modelado (com areaScope) mas desligado na UI.
model FeedPost {
  id              String               @id @default(cuid())
  authorUserId    String?
  author          User?                @relation("FeedPostAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  body            String
  visibility      FeedVisibility       @default(PUBLIC_INTERNAL)
  /// Area-alvo quando visibility = AREA. Chave livre (desligada na UI no v1).
  areaScope       String?
  status          FeedContentStatus    @default(VISIBLE)
  pinned          Boolean              @default(false)
  removedByUserId String?
  removedAt       DateTime?
  removalReason   String?
  editedAt        DateTime?
  comments        FeedComment[]
  reactions       FeedReaction[]
  attachments     FeedPostAttachment[]
  mentions        FeedMention[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([status, pinned, createdAt])
  @@index([visibility, areaScope, createdAt])
  @@index([authorUserId])
}

/// Comentario de um post do feed. onDelete Cascade no post: apagar o post leva
/// os comentarios junto. Autoria SetNull (preserva o comentario sem o autor).
/// Mesmo padrao de soft delete/moderacao/edicao do FeedPost.
model FeedComment {
  id              String            @id @default(cuid())
  postId          String
  post            FeedPost          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorUserId    String?
  author          User?             @relation("FeedCommentAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  body            String
  status          FeedContentStatus @default(VISIBLE)
  removedByUserId String?
  removedAt       DateTime?
  removalReason   String?
  editedAt        DateTime?
  reactions       FeedReaction[]
  mentions        FeedMention[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([postId, status, createdAt])
  @@index([authorUserId])
}

/// Reacao (emoji) de um usuario a um post OU a um comentario, nunca aos dois.
/// O XOR `(postId IS NOT NULL) <> (commentId IS NOT NULL)` e a unicidade
/// idempotente (um usuario, um emoji, por post/comentario) sao garantidos por
/// CHECK + indices unicos PARCIAIS na migration SQL — o @@unique do Prisma nao
/// expressa o WHERE parcial, entao NAO ha @@unique aqui (vide migration.sql).
/// onDelete Cascade em todas as FKs: a reacao some com o autor/post/comentario.
model FeedReaction {
  id        String       @id @default(cuid())
  emoji     String
  userId    String
  user      User         @relation("FeedReactionUser", fields: [userId], references: [id], onDelete: Cascade)
  postId    String?
  post      FeedPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   FeedComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([postId])
  @@index([commentId])
  @@index([userId])
}

/// Anexo (imagem/arquivo) de um post do feed (v1: anexo so no POST). Espelha
/// ExpenseAttachment: bucket privado + storageKey; a URL e sempre assinada.
/// 1:N com FeedPost, onDelete Cascade (anexos somem com o post).
model FeedPostAttachment {
  id               String   @id @default(cuid())
  postId           String
  post             FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  fileName         String
  contentType      String
  size             Int
  storageBucket    String
  storageKey       String
  uploadedByUserId String?
  createdAt        DateTime @default(now())

  @@index([postId])
  @@index([uploadedByUserId])
}

/// Mencao (@) de um usuario num post OU num comentario, nunca nos dois. Espelha o
/// FeedReaction: XOR `(postId IS NOT NULL) <> (commentId IS NOT NULL)` + indices
/// unicos PARCIAIS (um usuario mencionado no maximo uma vez por post/comentario)
/// garantidos na migration SQL (o @@unique do Prisma nao expressa o WHERE parcial).
/// onDelete Cascade em todas as FKs: a mencao some com o usuario/post/comentario.
model FeedMention {
  id              String       @id @default(cuid())
  mentionedUserId String
  mentionedUser   User         @relation("FeedMentionUser", fields: [mentionedUserId], references: [id], onDelete: Cascade)
  postId          String?
  post            FeedPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId       String?
  comment         FeedComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())

  @@index([postId])
  @@index([commentId])
  @@index([mentionedUserId])
}

/// Checkpoint / 1-on-1 (Melhoria #4, fatia 1). Registro de acompanhamento de um
/// consultor feito pelo GESTOR (so gestor registra; regra de app). type distingue
/// a conversa 1-on-1 (PRIVATE por padrao: o consultor nao ve) do checkpoint amplo.
/// Cascade no consultor (o registro nao existe sem o avaliado); managerUserId e
/// relatedProjectId sao SetNull (preservam o historico se o usuario/projeto sair).
/// Campos de voz/IA (audioStorageKey, transcription, transcriptionStatus,
/// extractionStatus) sao apoio para a fatia de IA — sem logica no banco. A
/// extracao gera Opportunity/Case (relacoes abaixo) e Skills via SkillSuggestion
/// (convencao sourceEntryIds = ["checkpoint:<id>"], sem modelo proprio aqui).
model Checkpoint {
  id                  String                     @id @default(cuid())
  consultantId        String
  consultant          Consultant                 @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  managerUserId       String?
  manager             User?                      @relation("CheckpointManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  relatedProjectId    String?
  relatedProject      Project?                   @relation(fields: [relatedProjectId], references: [id], onDelete: SetNull)
  type                CheckpointType
  occurredAt          DateTime
  weekStart           DateTime?
  weekEnd             DateTime?
  title               String?
  notes               String?
  audioStorageKey     String?
  transcription       String?
  transcriptionStatus TranscriptionStatus        @default(NONE)
  extractionStatus    CheckpointExtractionStatus @default(NONE)
  extractedAt         DateTime?
  status              CheckpointStatus           @default(DRAFT)
  visibility          CheckpointVisibility       @default(PRIVATE)
  opportunities       Opportunity[]
  cases               Case[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([consultantId])
  @@index([consultantId, occurredAt])
  @@index([managerUserId])
  @@index([status])
  @@index([extractionStatus])
}

/// Oportunidade (Melhoria #4): chance FUTURA a agir, INTERNA + handoff manual (sem
/// CRM). Pode nascer de um Checkpoint (sourceCheckpointId) e/ou ser gerada por IA
/// (aiGenerated) — nesse caso entra como status PENDING para curadoria humana.
/// Todas as FKs sao opcionais com onDelete SetNull para preservar o insight
/// comercial mesmo se a origem (checkpoint/consultor/cliente/projeto/usuario) sair.
/// sourceQuote guarda o trecho da conversa que originou a sugestao (rastreio da IA).
model Opportunity {
  id                 String                  @id @default(cuid())
  sourceCheckpointId String?
  sourceCheckpoint   Checkpoint?             @relation(fields: [sourceCheckpointId], references: [id], onDelete: SetNull)
  consultantId       String?
  consultant         Consultant?             @relation(fields: [consultantId], references: [id], onDelete: SetNull)
  relatedClientId    String?
  relatedClient      Client?                 @relation(fields: [relatedClientId], references: [id], onDelete: SetNull)
  relatedProjectId   String?
  relatedProject     Project?                @relation(fields: [relatedProjectId], references: [id], onDelete: SetNull)
  kind               OpportunityKind
  title              String
  description        String?
  priority           OpportunityPriority     @default(MEDIUM)
  sourceQuote        String?
  aiGenerated        Boolean                 @default(false)
  status             CheckpointInsightStatus @default(PENDING)
  decidedByUserId    String?
  decidedBy          User?                   @relation("OpportunityDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  decidedAt          DateTime?
  ownerUserId        String?
  owner              User?                   @relation("OpportunityOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([sourceCheckpointId])
  @@index([relatedClientId])
  @@index([status])
}

/// Case (Melhoria #4): entrega CONCLUIDA digna de referencia, INTERNO + handoff
/// manual. Pode nascer de um Checkpoint (sourceCheckpointId) e/ou da IA
/// (aiGenerated). stage e a maturidade interna (DRAFT_INSIGHT -> APPROVED ->
/// PUBLISHABLE); status e a curadoria do insight (PENDING/ACCEPTED/DISMISSED).
/// clientConsentState e texto livre do estado de consentimento do cliente para uso
/// comercial (regra no servidor). Todas as FKs SetNull preservam o case se a origem
/// sair. sourceQuote guarda o trecho da conversa que originou a sugestao.
model Case {
  id                 String                  @id @default(cuid())
  sourceCheckpointId String?
  sourceCheckpoint   Checkpoint?             @relation(fields: [sourceCheckpointId], references: [id], onDelete: SetNull)
  consultantId       String?
  consultant         Consultant?             @relation(fields: [consultantId], references: [id], onDelete: SetNull)
  relatedClientId    String?
  relatedClient      Client?                 @relation(fields: [relatedClientId], references: [id], onDelete: SetNull)
  relatedProjectId   String?
  relatedProject     Project?                @relation(fields: [relatedProjectId], references: [id], onDelete: SetNull)
  title              String
  summary            String?
  outcome            String?
  stage              CaseStage               @default(DRAFT_INSIGHT)
  clientConsentState String?
  sourceQuote        String?
  aiGenerated        Boolean                 @default(false)
  status             CheckpointInsightStatus @default(PENDING)
  decidedByUserId    String?
  decidedBy          User?                   @relation("CaseDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)
  decidedAt          DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([sourceCheckpointId])
  @@index([relatedClientId])
  @@index([status])
  @@index([stage])
}
