{
  "name": "jumpflow",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @jumpflow/web",
    "build": "npm run build --workspace @jumpflow/web",
    "lint": "npm run lint --workspace @jumpflow/web",
    "typecheck": "npm run typecheck --workspace @jumpflow/web",
    "test": "npm run test --workspace @jumpflow/web",
    "test:watch": "npm run test:watch --workspace @jumpflow/web",
    "db:generate": "npm run db:generate --workspace @jumpflow/database",
    "db:migrate": "npm run db:migrate --workspace @jumpflow/database",
    "db:deploy": "npm run db:deploy --workspace @jumpflow/database",
    "db:seed": "npm run db:seed --workspace @jumpflow/database",
    "db:studio": "npm run db:studio --workspace @jumpflow/database"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}

